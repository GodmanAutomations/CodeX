{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeX Coding Anchor Tool Intent",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "scope", "risk", "expected_decision"],
  "properties": {
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "expected_decision": {
      "type": "string",
      "minLength": 1
    }
  }
}
