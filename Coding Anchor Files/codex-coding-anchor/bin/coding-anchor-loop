#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
QUEUE="${CODING_ANCHOR_QUEUE:-$ROOT/state/work-queue.json}"
PYTHON_BIN="${CODING_ANCHOR_PYTHON:-python3}"
if [ -x "$ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$ROOT/.venv/bin/python"
fi
MAX_SLICES=""
DRY_RUN=0

usage() {
  cat <<'EOF'
usage: coding-anchor-loop [--dry-run] [--max-slices N]

Preview or guide the next safe queue slices. This is not a background daemon.
Without --dry-run it prints the next task and stops for the agent to execute it.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --max-slices)
      MAX_SLICES="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

"$PYTHON_BIN" - "$QUEUE" "$DRY_RUN" "$MAX_SLICES" <<'PY'
import copy
import json
import sys

queue_path = sys.argv[1]
dry_run = sys.argv[2] == "1"
max_slices_arg = sys.argv[3]

with open(queue_path, "r", encoding="utf-8") as handle:
    queue = json.load(handle)

max_slices = int(max_slices_arg) if max_slices_arg else int(queue["policy"]["max_auto_slices_default"])
priority_rank = {"high": 0, "medium": 1, "low": 2}
tasks = copy.deepcopy(queue.get("tasks", []))

def blocked_reasons(task, done):
    reasons = []
    missing = [dep for dep in task.get("dependencies", []) if dep not in done]
    if missing:
        reasons.append("waiting on dependencies: " + ", ".join(missing))
    if not task.get("safe_to_auto", False):
        reasons.append("safe_to_auto is false")
    if task.get("stop_gates"):
        reasons.append("stop gates: " + ", ".join(task["stop_gates"]))
    return reasons

planned = []
for _ in range(max_slices):
    done = {task["id"] for task in tasks if task.get("status") == "done"}
    in_progress = [task for task in tasks if task.get("status") == "in_progress"]
    blocked_in_progress = [
        task for task in in_progress if blocked_reasons(task, done)
    ]
    if blocked_in_progress:
        print("Current in-progress slice is blocked.")
        for task in blocked_in_progress:
            print(f"- {task['id']}: {'; '.join(blocked_reasons(task, done))}")
        sys.exit(1)
    eligible = [
        task
        for task in tasks
        if task.get("status") == "pending" and not blocked_reasons(task, done)
    ]
    eligible.sort(key=lambda task: (priority_rank.get(task.get("priority"), 9), tasks.index(task)))
    selected = in_progress[0] if in_progress else (eligible[0] if eligible else None)
    if selected is None:
        break
    planned.append({"task": copy.deepcopy(selected), "actual_status": selected.get("status")})
    if dry_run:
        selected["status"] = "done"
    else:
        break

if not planned:
    print("No safe next slices available.")
    sys.exit(1)

if dry_run:
    print(f"dry_run_slices: {len(planned)}")
else:
    print("next_slice:")

for index, item in enumerate(planned, start=1):
    task = item["task"]
    print(f"{index}. {task['id']} — {task['title']}")
    print(f"   status: {item['actual_status']}")
    if dry_run:
        print("   preview: simulated completion for dependency planning only")
    print(f"   priority: {task['priority']}")
    if task.get("verification"):
        print("   verification:")
        for check in task["verification"]:
            print(f"   - {check}")
    if task.get("reviewer_required"):
        print("   reviewer: required")
    if task.get("notes"):
        print(f"   notes: {task['notes']}")

if not dry_run:
    print("")
    print("Execute this slice, verify it, run reviewer if required, then mark done:")
    print(f"bin/coding-anchor-done {planned[0]['task']['id']} --details \"<verification evidence>\"")
PY
