#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE="$ROOT/state/last-heartbeat.json"
PYTHON_BIN="${CODING_ANCHOR_PYTHON:-python3}"
if [ -x "$ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$ROOT/.venv/bin/python"
fi

mkdir -p "$ROOT/state"

"$PYTHON_BIN" - "$STATE" "$ROOT" <<'PY'
import datetime
import json
import sys

state_path, root = sys.argv[1:3]
payload = {
    "status": "alive",
    "checked_at": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
    "root": root,
    "message": "CodeX Coding Anchor heartbeat recorded.",
}
with open(state_path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")
PY

printf 'heartbeat: %s\n' "$STATE"
