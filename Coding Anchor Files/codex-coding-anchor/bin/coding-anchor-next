#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
QUEUE="${CODING_ANCHOR_QUEUE:-$ROOT/state/work-queue.json}"
PYTHON_BIN="${CODING_ANCHOR_PYTHON:-python3}"
if [ -x "$ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$ROOT/.venv/bin/python"
fi
JSON=0

usage() {
  cat <<'EOF'
usage: coding-anchor-next [--json]

Print the current in-progress task or next safe unblocked pending task.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json)
      JSON=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

"$PYTHON_BIN" - "$QUEUE" "$JSON" <<'PY'
import json
import sys

queue_path = sys.argv[1]
emit_json = sys.argv[2] == "1"

priority_rank = {"high": 0, "medium": 1, "low": 2}

with open(queue_path, "r", encoding="utf-8") as handle:
    queue = json.load(handle)

tasks = queue.get("tasks", [])
by_id = {task["id"]: task for task in tasks}
done = {task["id"] for task in tasks if task.get("status") == "done"}

def blocked_reasons(task):
    reasons = []
    missing = [dep for dep in task.get("dependencies", []) if dep not in done]
    if missing:
        reasons.append("waiting on dependencies: " + ", ".join(missing))
    if not task.get("safe_to_auto", False):
        reasons.append("safe_to_auto is false")
    if task.get("stop_gates"):
        reasons.append("stop gates: " + ", ".join(task["stop_gates"]))
    return reasons

in_progress = [task for task in tasks if task.get("status") == "in_progress"]
if len(in_progress) > 1:
    payload = {
        "status": "queue_conflict",
        "reason": "multiple in_progress tasks",
        "tasks": [{"id": task["id"], "title": task["title"]} for task in in_progress],
    }
    if emit_json:
        print(json.dumps(payload, indent=2))
    else:
        print("Queue conflict: multiple in_progress tasks.")
        for task in in_progress:
            print(f"- {task['id']}: {task['title']}")
    sys.exit(1)

blocked_in_progress = [
    {"id": task["id"], "title": task["title"], "reasons": blocked_reasons(task)}
    for task in in_progress
    if blocked_reasons(task)
]
if blocked_in_progress:
    payload = {"status": "blocked_in_progress", "blocked": blocked_in_progress}
    if emit_json:
        print(json.dumps(payload, indent=2))
    else:
        print("Current in-progress slice is blocked.")
        for item in blocked_in_progress:
            print(f"- {item['id']}: {item['title']} ({'; '.join(item['reasons'])})")
    sys.exit(1)

eligible_pending = [
    task
    for task in tasks
    if task.get("status") == "pending" and not blocked_reasons(task)
]
eligible_pending.sort(key=lambda task: (priority_rank.get(task.get("priority"), 9), tasks.index(task)))

selected = in_progress[0] if in_progress else (eligible_pending[0] if eligible_pending else None)

if selected is None:
    blocked = [
        {
            "id": task["id"],
            "title": task["title"],
            "status": task.get("status"),
            "reasons": blocked_reasons(task),
        }
        for task in tasks
        if task.get("status") in {"in_progress", "pending"}
    ]
    payload = {"status": "no_eligible_task", "blocked": blocked}
    if emit_json:
        print(json.dumps(payload, indent=2))
    else:
        print("No eligible next slice.")
        for item in blocked:
            if item["reasons"]:
                print(f"- {item['id']}: {item['title']} ({'; '.join(item['reasons'])})")
    sys.exit(1)

payload = {
    "status": "ok",
    "task": selected,
    "selection": "in_progress" if selected in in_progress else "pending_unblocked"
}

if emit_json:
    print(json.dumps(payload, indent=2))
else:
    print(f"next: {selected['id']} — {selected['title']}")
    print(f"status: {selected['status']}")
    print(f"priority: {selected['priority']}")
    print(f"selection: {payload['selection']}")
    if selected.get("dependencies"):
        print("dependencies: " + ", ".join(selected["dependencies"]))
    if selected.get("verification"):
        print("verification:")
        for check in selected["verification"]:
            print(f"- {check}")
    if selected.get("notes"):
        print(f"notes: {selected['notes']}")
PY
