#!/usr/bin/env bash
set -euo pipefail

ROOT="/Users/stephengodman/CodeX"
RECEIPT_DIR="$ROOT/receipts/startup"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
RECEIPT="$RECEIPT_DIR/${STAMP}-room-doctor.txt"

mkdir -p "$RECEIPT_DIR"
exec > >(tee "$RECEIPT") 2>&1

printf 'CODEX ROOM DOCTOR\n'
printf '=================\n'
printf 'room: %s\n' "$ROOT"
printf 'receipt: %s\n\n' "$RECEIPT"

printf '## Standalone Preflight\n\n'
"$ROOT/bin/codex-ensure-standalone" --check

printf '\n## Codex MCP List\n\n'
codex mcp list

printf '\n## Codex Doctor\n\n'
DOCTOR_TERM="${TERM:-xterm-256color}"
if [[ "$DOCTOR_TERM" == "dumb" ]]; then
  DOCTOR_TERM="xterm-256color"
fi
TERM="$DOCTOR_TERM" codex doctor

printf '\n## Room Startup\n\n'
"$ROOT/bin/codex-startup"

printf '\nroom doctor receipt saved: %s\n' "$RECEIPT"
