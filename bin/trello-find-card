#!/usr/bin/env python3
"""Find Trello cards by name and show the useful identifiers."""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path


LAUNCHER = Path("/Users/stephengodman/Candice-Code/mcp_servers/trello_mcp_launcher.sh")


def run_launcher(args: list[str]) -> dict:
    result = subprocess.run(
        [str(LAUNCHER), *args],
        check=False,
        capture_output=True,
        text=True,
        timeout=90,
    )
    output = result.stdout.strip() or result.stderr.strip()
    try:
        payload = json.loads(output)
    except json.JSONDecodeError:
        payload = {
            "ok": False,
            "error": output[:1200] or f"launcher exited {result.returncode}",
            "returncode": result.returncode,
        }
    if result.returncode != 0 and payload.get("ok") is not False:
        payload["ok"] = False
        payload["returncode"] = result.returncode
    return payload


def format_cards(payload: dict) -> str:
    if not payload.get("ok"):
        return f"Trello card search: {payload.get('error') or 'search failed'}"
    cards = payload.get("cards") or []
    query = payload.get("query") or ""
    if not cards:
        return f"No open cards found for: {query}"

    lines = [f"Found {len(cards)} card(s) for: {query}"]
    for index, card in enumerate(cards, start=1):
        labels = ", ".join(card.get("labels") or [])
        details = []
        if card.get("idList"):
            details.append(f"list_id {card.get('idList')}")
        if labels:
            details.append(f"labels {labels}")
        suffix = f" ({'; '.join(details)})" if details else ""
        lines.extend(
            [
                "",
                f"{index}. {card.get('name') or 'Untitled'}{suffix}",
                f"   id: {card.get('id')}",
                f"   url: {card.get('shortUrl')}",
            ]
        )
    return "\n".join(lines)


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Find Trello cards by name")
    parser.add_argument("query", nargs="+", help="Card search text, for example Byrd or Henderson.")
    parser.add_argument("--board", default="memphis", help="Board alias. Default: memphis.")
    parser.add_argument("--limit", type=int, default=10)
    parser.add_argument("--json", action="store_true", help="Return raw JSON.")
    args = parser.parse_args(argv)

    query = " ".join(args.query).strip()
    payload = run_launcher(
        [
            "--search-cards",
            "--board",
            args.board,
            "--query",
            query,
            "--limit-cards",
            str(max(1, min(args.limit, 100))),
        ]
    )
    print(json.dumps(payload, indent=2, sort_keys=True) if args.json else format_cards(payload))
    return 0 if payload.get("ok") else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
