#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RECEIPT_DIR="$ROOT/receipts/regression"
STAMP="$(date '+%Y%m%d-%H%M%S')"
PASS_COUNT=0
FAIL_COUNT=0
TMP_DIR=""
RECEIPT=""
RECEIPT_TMP=""
COMPLETED=0

cleanup() {
  local exit_code=$?
  if [ "$exit_code" -ne 0 ] && [ "$COMPLETED" -eq 0 ] && [ -n "$RECEIPT" ] && [ -f "$RECEIPT" ]; then
    printf 'INCOMPLETE exit=%s\n' "$exit_code" >>"$RECEIPT"
  fi
  if [ -n "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
  if [ -n "$RECEIPT_TMP" ] && [ -f "$RECEIPT_TMP" ]; then
    rm -f "$RECEIPT_TMP"
  fi
}
trap cleanup EXIT

mkdir -p "$RECEIPT_DIR"
TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/codex-identity-regression.XXXXXX")" || {
  echo "error: failed to create regression temp dir" >&2
  exit 1
}
RECEIPT_TMP="$(mktemp "$RECEIPT_DIR/${STAMP}-identity-regression.XXXXXX")" || {
  echo "error: failed to create regression receipt" >&2
  exit 1
}
RECEIPT="${RECEIPT_TMP}.txt"
mv "$RECEIPT_TMP" "$RECEIPT"
RECEIPT_TMP=""

log() {
  printf '%s\n' "$*" >>"$RECEIPT"
}

pass() {
  PASS_COUNT=$((PASS_COUNT + 1))
  log "PASS $*"
}

fail() {
  FAIL_COUNT=$((FAIL_COUNT + 1))
  log "FAIL $*"
}

require_file() {
  local path="$1"
  if [ -f "$ROOT/$path" ]; then
    pass "file $path"
  else
    fail "missing file $path"
  fi
}

require_exec() {
  local path="$1"
  if [ -x "$ROOT/$path" ]; then
    pass "executable $path"
  else
    fail "missing executable $path"
  fi
}

require_contains() {
  local path="$1"
  local needle="$2"
  local label="$3"
  if [ ! -f "$ROOT/$path" ]; then
    fail "$label (missing file $path)"
    return
  fi
  if grep -Fq -- "$needle" "$ROOT/$path"; then
    pass "$label"
  else
    fail "$label"
  fi
}

require_not_contains() {
  local path="$1"
  local needle="$2"
  local label="$3"
  if [ ! -f "$ROOT/$path" ]; then
    fail "$label (missing file $path)"
    return
  fi
  if grep -Fq -- "$needle" "$ROOT/$path"; then
    fail "$label"
  else
    pass "$label"
  fi
}

require_command_output_contains() {
  local label="$1"
  local output_file="$2"
  local needle="$3"
  if grep -Fq -- "$needle" "$output_file"; then
    pass "$label"
  else
    fail "$label"
  fi
}

run_capture() {
  local label="$1"
  local output_file="$2"
  shift 2
  if "$@" >"$output_file" 2>&1; then
    pass "$label command exits 0"
  else
    fail "$label command exits 0"
  fi
}

run_health_capture() {
  local label="$1"
  local output_file="$2"
  local status_code
  shift 2
  if "$@" >"$output_file" 2>&1; then
    status_code=0
  else
    status_code=$?
  fi
  if [ "$status_code" -le 1 ]; then
    pass "$label exits with health status (rc=$status_code)"
  else
    fail "$label exits with health status (rc=$status_code)"
    if [ -s "$output_file" ]; then
      while IFS= read -r line; do
        log "DETAIL $label: $line"
      done < <(tail -12 "$output_file")
    fi
  fi
}

cd "$ROOT"

log "CodeX Identity Regression Harness"
log "root: $ROOT"
log "checked_at: $(date '+%Y-%m-%dT%H:%M:%S%z')"
log ""

for file in \
  "CODEX-OWNED-BOOT.md" \
  "CODEX-PERSONAL-VOICE-PROFILE.md" \
  "CODEX-PERSONAL-MODES.md" \
  "CODEX-IDENTITY-REGRESSION.md" \
  "CODEX-THREAD-PROFILE.md" \
  "CODEX-BEST-LANE.md" \
  "CODEX-STICKY-STARTUP.md" \
  "CODEX-REGRESSION-HARNESS.md" \
  "CODEX-CLAUDE-REVIEWER.md" \
  "CODEX-STARTUP-DROPIN.md" \
  "docs/agent-protocol.md" \
  "TICKET-CODEX-OWNED-STARTUP-INTEGRATION.md" \
  "AGENTS.md" \
  "START-HERE.md" \
  "STARTUP.md" \
  "BOOT.md" \
  "QUICKSTART.md" \
  "README.md" \
  "ROUTING-CARD.md"; do
  require_file "$file"
done

require_exec "bin/codex-startup"
require_exec "bin/codex-room"
require_exec "bin/codex-identity-regression"
require_exec "bin/codex-check"
require_exec "bin/codex-ensure-standalone"
require_exec "bin/codex-claude-review"
require_file "bin/lib/codex-common.sh"

for file in \
  "CODEX-STICKY-STARTUP.md" \
  "AGENTS.md" \
  "START-HERE.md" \
  "STARTUP.md" \
  "BOOT.md" \
  "QUICKSTART.md" \
  "bin/codex-startup"; do
  require_contains "$file" "CODEX-OWNED-BOOT.md" "$file loads owned boot"
  require_contains "$file" "CODEX-THREAD-PROFILE.md" "$file loads thread profile"
  require_contains "$file" "CODEX-PERSONAL-VOICE-PROFILE.md" "$file loads personal voice profile"
  require_contains "$file" "CODEX-PERSONAL-MODES.md" "$file loads personal modes"
  require_contains "$file" "CODEX-IDENTITY-REGRESSION.md" "$file loads identity regression"
done

require_contains "START-HERE.md" "docs/agent-protocol.md" "START-HERE.md surfaces advisor protocol"
require_contains "BOOT.md" "docs/agent-protocol.md" "BOOT.md surfaces advisor protocol"
require_contains "BOOT.md" "CODEX-PERSONAL-VOICE-PROFILE.md" "BOOT.md names personal voice profile"
require_contains "BOOT.md" "CODEX-PERSONAL-MODES.md" "BOOT.md names personal modes"
require_contains "BOOT.md" "CODEX-IDENTITY-REGRESSION.md" "BOOT.md names identity regression"
require_contains "BOOT.md" "codex-identity-regression" "BOOT.md names regression harness command"

require_contains "bin/codex-startup" "CODEX-REGRESSION-HARNESS.md" "startup surfaces regression harness docs"
require_contains "bin/codex-startup" "codex-identity-regression" "startup surfaces regression harness command"
require_contains "bin/codex-startup" "CODEX-CLAUDE-REVIEWER.md" "startup surfaces Claude reviewer docs"
require_contains "bin/codex-startup" "codex-claude-review" "startup surfaces Claude reviewer command"
require_contains "bin/codex-startup" "--read-only" "startup has read-only verification mode"
require_contains "bin/codex-room" "Identity Regression Harness" "room brief surfaces regression harness"
require_contains "bin/codex-room" "CODEX-REGRESSION-HARNESS.md" "room brief surfaces regression docs"
require_contains "bin/codex-room" "codex-identity-regression" "room brief surfaces regression command"
require_contains "bin/codex-room" "Claude Reviewer" "room brief surfaces Claude reviewer"
require_contains "bin/codex-room" "CODEX-CLAUDE-REVIEWER.md" "room brief surfaces Claude reviewer docs"
require_contains "bin/codex-room" "codex-claude-review" "room brief surfaces Claude reviewer command"
require_contains "bin/codex-room" "CODEX_ROOM_READONLY" "room brief has read-only verification mode"

startup_output="$TMP_DIR/codex-startup-regression.txt"
brief_output="$TMP_DIR/codex-room-brief-regression.txt"
handoff_output="$TMP_DIR/codex-room-handoff-regression.txt"
common_output="$TMP_DIR/codex-common-smoke.txt"
codex_check_output="$TMP_DIR/codex-check-tree-doctor.json"
codex_check_quick_output="$TMP_DIR/codex-check-quick.json"
codex_check_full_output="$TMP_DIR/codex-check-full.json"
codex_check_phone_output="$TMP_DIR/codex-check-phone.json"
codex_check_ensure_output="$TMP_DIR/codex-check-ensure-standalone.json"
codex_check_empty_only_output="$TMP_DIR/codex-check-empty-only.json"
codex_check_bad_profile_output="$TMP_DIR/codex-check-bad-profile.json"
ensure_standalone_json_output="$TMP_DIR/codex-ensure-standalone.json"
ensure_standalone_text_output="$TMP_DIR/codex-ensure-standalone.txt"
advisor_ignore_output="$TMP_DIR/advisor-receipts-ignore.txt"
tool_route_output="$TMP_DIR/codex-tool-route-pi.txt"
tool_route_pi5_output="$TMP_DIR/codex-tool-route-pi5.txt"
tool_route_comma_output="$TMP_DIR/codex-tool-route-comma.txt"
tool_route_plain_pi_output="$TMP_DIR/codex-tool-route-plain-pi.txt"
tool_route_negative_output="$TMP_DIR/codex-tool-route-pipeline.txt"
tool_route_topic_output="$TMP_DIR/codex-tool-route-topic.txt"
tool_route_api_output="$TMP_DIR/codex-tool-route-api.txt"
tool_route_epic_output="$TMP_DIR/codex-tool-route-epic.txt"
tool_route_non_pi_output="$TMP_DIR/codex-tool-route-non-pi.txt"
tool_route_pi_helper_output="$TMP_DIR/codex-tool-route-pi-helper.txt"

run_capture "startup read-only runtime" "$startup_output" "$ROOT/bin/codex-startup" --read-only
require_command_output_contains "startup runtime outputs owned boot" "$startup_output" "CODEX-OWNED-BOOT.md"
require_command_output_contains "startup runtime outputs thread profile" "$startup_output" "CODEX-THREAD-PROFILE.md"
require_command_output_contains "startup runtime outputs personal voice profile" "$startup_output" "CODEX-PERSONAL-VOICE-PROFILE.md"
require_command_output_contains "startup runtime outputs personal modes" "$startup_output" "CODEX-PERSONAL-MODES.md"
require_command_output_contains "startup runtime outputs identity regression" "$startup_output" "CODEX-IDENTITY-REGRESSION.md"
require_command_output_contains "startup runtime outputs regression harness" "$startup_output" "CODEX-REGRESSION-HARNESS.md"
require_command_output_contains "startup runtime outputs harness command" "$startup_output" "bin/codex-identity-regression"
require_command_output_contains "startup runtime outputs Claude reviewer" "$startup_output" "CODEX-CLAUDE-REVIEWER.md"
require_command_output_contains "startup runtime outputs Claude reviewer command" "$startup_output" "bin/codex-claude-review"
require_command_output_contains "startup runtime skips mutable checks" "$startup_output" "skipped in read-only startup preview"

run_capture "room brief read-only runtime" "$brief_output" env CODEX_ROOM_READONLY=1 "$ROOT/bin/codex-room" brief
require_command_output_contains "room brief runtime outputs harness section" "$brief_output" "## Identity Regression Harness"
require_command_output_contains "room brief runtime outputs harness docs" "$brief_output" "CODEX-REGRESSION-HARNESS.md"
require_command_output_contains "room brief runtime outputs harness command" "$brief_output" "bin/codex-identity-regression"
require_command_output_contains "room brief runtime outputs Claude reviewer section" "$brief_output" "## Claude Reviewer"
require_command_output_contains "room brief runtime outputs Claude reviewer docs" "$brief_output" "CODEX-CLAUDE-REVIEWER.md"
require_command_output_contains "room brief runtime outputs Claude reviewer command" "$brief_output" "bin/codex-claude-review"
require_command_output_contains "room brief runtime skips mutable memory status" "$brief_output" "Skipped in read-only room brief."

run_capture "room handoff read-only runtime" "$handoff_output" env CODEX_ROOM_READONLY=1 "$ROOT/bin/codex-room" handoff
require_command_output_contains "room handoff runtime outputs harness section" "$handoff_output" "## Identity Regression Harness"
require_command_output_contains "room handoff runtime outputs harness docs" "$handoff_output" "CODEX-REGRESSION-HARNESS.md"
require_command_output_contains "room handoff runtime outputs harness command" "$handoff_output" "bin/codex-identity-regression"
require_command_output_contains "room handoff runtime outputs Claude reviewer section" "$handoff_output" "## Claude Reviewer"
require_command_output_contains "room handoff runtime outputs Claude reviewer docs" "$handoff_output" "CODEX-CLAUDE-REVIEWER.md"
require_command_output_contains "room handoff runtime outputs Claude reviewer command" "$handoff_output" "bin/codex-claude-review"

run_capture "codex-common env scrub runtime" "$common_output" bash -c 'set -euo pipefail; unset CODEX_ROOT CODEX_BIN_DIR CODEX_COMMON_DIR; source "$1"; codex_init_paths; test "$CODEX_ROOT" = "$2"; test "$CODEX_BIN_DIR" = "$2/bin"; tmp="$(codex_mktemp_dir codex-common-regression)"; codex_cleanup_add "$tmp" "$tmp-missing"; test -d "$tmp"; FOO_SECRET=keep; export FOO_SECRET; codex_run_without_env FOO_SECRET -- bash -c '\''test -z "${FOO_SECRET:-}"'\''; test "$FOO_SECRET" = keep; if codex_run_without_env FOO_SECRET BAR >/dev/null 2>&1; then exit 1; fi; codex_cleanup_run; test ! -e "$tmp"; printf "common smoke ok\n"' bash "$ROOT/bin/lib/codex-common.sh" "$ROOT"
require_command_output_contains "codex-common env scrub leaves caller env intact" "$common_output" "common smoke ok"
run_capture "advisor receipts gitignore runtime" "$advisor_ignore_output" bash -c 'set -euo pipefail; cd "$1"; path="receipts/advisor/example.md"; printf "%s\n" "$path" | git check-ignore --stdin --no-index | grep -Fx "$path" >/dev/null; test -z "$(git ls-files receipts/advisor)"; printf "%s ignored and no tracked advisor receipts\n" "$path"' bash "$ROOT"
require_command_output_contains "advisor receipts gitignore runtime outputs ignored path" "$advisor_ignore_output" "receipts/advisor/example.md ignored and no tracked advisor receipts"
run_capture "codex-check tree doctor runtime" "$codex_check_output" "$ROOT/bin/codex-check" --json --only tree_steward_doctor
require_command_output_contains "codex-check runtime returns passing JSON" "$codex_check_output" '"ok": true'
run_health_capture "codex-check quick JSON runtime" "$codex_check_quick_output" "$ROOT/bin/codex-check" --json --profile quick
run_health_capture "codex-check full JSON runtime" "$codex_check_full_output" "$ROOT/bin/codex-check" --json --profile full
run_health_capture "codex-check phone JSON runtime" "$codex_check_phone_output" "$ROOT/bin/codex-check" --json --profile phone
run_capture "codex-check ensure standalone JSON runtime" "$codex_check_ensure_output" "$ROOT/bin/codex-check" --json --only ensure_standalone
if python3 - "$codex_check_quick_output" "$codex_check_full_output" "$codex_check_phone_output" "$codex_check_ensure_output" <<'PY'
import json
import sys

expected = {
    "quick": ("quick", False, {"status", "mcp_doctor", "tree_steward_doctor"}),
    "full": ("full", False, {"status", "mcp_doctor", "tree_steward_doctor", "ensure_standalone"}),
    "phone": ("phone", False, {"status", "mcp_doctor", "tree_steward_doctor", "phone_summary"}),
    # --only inherits codex-check's default profile while narrowing selected_checks.
    "ensure": ("quick", True, {"ensure_standalone"}),
}

errors = []
required_top = {
    "ok",
    "profile",
    "only",
    "selected_checks",
    "root",
    "generated_at",
    "checks",
    "summary",
    "safety",
}
required_check = {"name", "ok", "returncode", "kind", "duration_ms", "command"}
json_kinds = {"json"}
exit_kinds = {"exit-only"}

for label, path in zip(("quick", "full", "phone", "ensure"), sys.argv[1:]):
    try:
        with open(path, encoding="utf-8") as handle:
            payload = json.load(handle)
    except Exception as exc:
        errors.append(f"{label}: output is not valid JSON: {exc}")
        continue
    expected_profile, expected_only, expected_checks = expected[label]
    missing_top = sorted(required_top - set(payload))
    if missing_top:
        errors.append(f"{label}: missing top-level keys: {', '.join(missing_top)}")
    if payload.get("profile") != expected_profile:
        errors.append(f"{label}: profile mismatch: {payload.get('profile')!r}")
    if payload.get("only") != expected_only:
        errors.append(f"{label}: only mismatch: {payload.get('only')!r}")
    if not isinstance(payload.get("ok"), bool):
        errors.append(f"{label}: top-level ok is not boolean")
    summary = payload.get("summary")
    if not isinstance(summary, dict) or not isinstance(summary.get("passed"), int):
        errors.append(f"{label}: summary.passed missing or not integer")
    if not isinstance(summary, dict) or not isinstance(summary.get("failed"), int):
        errors.append(f"{label}: summary.failed missing or not integer")
    selected = payload.get("selected_checks")
    if not isinstance(selected, list):
        errors.append(f"{label}: selected_checks missing or not list")
        selected_names = set()
    else:
        selected_names = set(selected)
    if selected_names != expected_checks:
        errors.append(f"{label}: selected_checks mismatch: {selected!r}")
    checks = payload.get("checks")
    if not isinstance(checks, list) or not checks:
        errors.append(f"{label}: checks missing or empty")
        continue
    check_names = {check.get("name") for check in checks if isinstance(check, dict)}
    if check_names != selected_names:
        errors.append(f"{label}: check names do not match selected_checks: {sorted(check_names)!r}")
    for index, check in enumerate(checks):
        name = check.get("name", f"<index {index}>")
        missing_check = sorted(required_check - set(check))
        if missing_check:
            errors.append(f"{label}:{name}: missing check keys: {', '.join(missing_check)}")
        if not isinstance(check.get("name"), str) or not check.get("name"):
            errors.append(f"{label}:{name}: name missing or not string")
        if not isinstance(check.get("ok"), bool):
            errors.append(f"{label}:{name}: ok is not boolean")
        if not isinstance(check.get("returncode"), int):
            errors.append(f"{label}:{name}: returncode is not integer")
        if not isinstance(check.get("duration_ms"), int):
            errors.append(f"{label}:{name}: duration_ms is not integer")
        if not isinstance(check.get("command"), list) or not check.get("command"):
            errors.append(f"{label}:{name}: command missing or empty")
        kind = check.get("kind")
        if kind in json_kinds:
            if "payload" not in check and "error" not in check:
                errors.append(f"{label}:{name}: json check lacks payload or error")
            if "payload" in check and not isinstance(check["payload"], dict):
                errors.append(f"{label}:{name}: payload is not object")
        elif kind in exit_kinds:
            if "stdout_tail" not in check:
                errors.append(f"{label}:{name}: exit-only check lacks stdout_tail")
            if "stdout_tail" in check and not isinstance(check["stdout_tail"], str):
                errors.append(f"{label}:{name}: stdout_tail is not string")
            if "stderr_tail" in check and not isinstance(check["stderr_tail"], str):
                errors.append(f"{label}:{name}: stderr_tail is not string")
        else:
            errors.append(f"{label}:{name}: unknown kind {kind!r}")

if errors:
    for error in errors:
        print(error, file=sys.stderr)
    sys.exit(1)
PY
then
  pass "codex-check JSON contract runtime validates profiles and ensure standalone"
else
  fail "codex-check JSON contract runtime validates profiles and ensure standalone"
fi
run_capture "ensure standalone JSON runtime" "$ensure_standalone_json_output" "$ROOT/bin/codex-ensure-standalone" --check --json
require_command_output_contains "ensure standalone JSON runtime includes ok key" "$ensure_standalone_json_output" '"ok":'
require_command_output_contains "ensure standalone JSON runtime includes receipt" "$ensure_standalone_json_output" '"receipt":'
if python3 - "$ensure_standalone_json_output" <<'PY'
import json
import pathlib
import sys

errors = []
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
receipt_value = payload.get("receipt")
receipt = pathlib.Path(receipt_value) if receipt_value else None
if payload.get("ok") is not True:
    errors.append("ok is not true")
if payload.get("mode") != "check":
    errors.append("mode is not check")
if payload.get("summary", {}).get("fail") != 0:
    errors.append("summary.fail is not zero")
if not isinstance(payload.get("checks"), list) or not payload["checks"]:
    errors.append("checks is missing or empty")
if "generated_at" not in payload:
    errors.append("generated_at is missing")
if receipt is None:
    errors.append("receipt is missing")
elif not receipt.exists():
    errors.append(f"receipt does not exist: {receipt}")
elif receipt.stat().st_size == 0:
    errors.append(f"receipt is empty: {receipt}")
if errors:
    for error in errors:
        print(error, file=sys.stderr)
    sys.exit(1)
PY
then
  pass "ensure standalone JSON runtime parses top-level contract"
else
  fail "ensure standalone JSON runtime parses top-level contract"
fi
run_capture "ensure standalone text runtime" "$ensure_standalone_text_output" "$ROOT/bin/codex-ensure-standalone" --check
require_command_output_contains "ensure standalone text runtime keeps human header" "$ensure_standalone_text_output" "CODEX STANDALONE PREFLIGHT"
require_command_output_contains "ensure standalone text runtime keeps summary" "$ensure_standalone_text_output" "summary: pass="
require_command_output_contains "ensure standalone text runtime keeps receipt" "$ensure_standalone_text_output" "receipt saved:"
set +e
"$ROOT/bin/codex-check" --json --only "" >"$codex_check_empty_only_output" 2>&1
codex_check_empty_only_rc=$?
set -e
if [ "$codex_check_empty_only_rc" -eq 2 ] && grep -Fq '"error": "--only did not include any check names"' "$codex_check_empty_only_output"; then
  pass "codex-check empty --only exits with usage error"
else
  while IFS= read -r line; do
    log "DETAIL codex-check empty --only: $line"
  done <"$codex_check_empty_only_output"
  fail "codex-check empty --only exits with usage error"
fi
if "$ROOT/bin/codex-check" --json --profile bogus >"$codex_check_bad_profile_output" 2>&1; then
  codex_check_bad_profile_rc=0
else
  codex_check_bad_profile_rc=$?
fi
if [ "$codex_check_bad_profile_rc" -eq 2 ]; then
  pass "codex-check bad profile exits with usage error"
else
  while IFS= read -r line; do
    log "DETAIL codex-check bad profile: $line"
  done <"$codex_check_bad_profile_output"
  fail "codex-check bad profile exits with usage error"
fi

run_capture "tool route pi punctuation runtime" "$tool_route_output" "$ROOT/bin/codex-tool-route" "check pi?"
require_command_output_contains "tool route pi punctuation hits backend lane" "$tool_route_output" "route: Pi/backend truth"
run_capture "tool route pi5 runtime" "$tool_route_pi5_output" "$ROOT/bin/codex-tool-route" "pi5"
require_command_output_contains "tool route pi5 hits backend lane" "$tool_route_pi5_output" "route: Pi/backend truth"
run_capture "tool route pi comma runtime" "$tool_route_comma_output" "$ROOT/bin/codex-tool-route" "pi, restart"
require_command_output_contains "tool route pi comma hits backend lane" "$tool_route_comma_output" "route: Pi/backend truth"
run_capture "tool route plain pi runtime" "$tool_route_plain_pi_output" "$ROOT/bin/codex-tool-route" "use pi now"
require_command_output_contains "tool route plain pi hits backend lane" "$tool_route_plain_pi_output" "route: Pi/backend truth"
run_capture "tool route pi substring runtime" "$tool_route_negative_output" "$ROOT/bin/codex-tool-route" "pipeline status"
require_command_output_contains "tool route pi substring does not hit backend lane" "$tool_route_negative_output" "route: Smallest safe first read"
run_capture "tool route topic substring runtime" "$tool_route_topic_output" "$ROOT/bin/codex-tool-route" "topic about routing"
require_command_output_contains "tool route topic substring does not hit backend lane" "$tool_route_topic_output" "route: Smallest safe first read"
run_capture "tool route api substring runtime" "$tool_route_api_output" "$ROOT/bin/codex-tool-route" "api call"
require_command_output_contains "tool route api substring does not hit backend lane" "$tool_route_api_output" "route: API/library behavior"
run_capture "tool route epic substring runtime" "$tool_route_epic_output" "$ROOT/bin/codex-tool-route" "epic next slice"
require_command_output_contains "tool route epic substring does not hit backend lane" "$tool_route_epic_output" "route: Long auto-mode work"
run_capture "tool route non-pi hyphen runtime" "$tool_route_non_pi_output" "$ROOT/bin/codex-tool-route" "non-pi-mode"
require_command_output_contains "tool route non-pi hyphen does not hit backend lane" "$tool_route_non_pi_output" "route: Smallest safe first read"
