#!/usr/bin/env bash
set -euo pipefail

ROOM="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MEMORY="$ROOM/memory/codex_memory.py"

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    cat <<'HELP'
CodeX room helper

Usage:
  codex-room status
  codex-room brief
  codex-room recall QUERY
  codex-room remember KIND KEY VALUE [TAGS]
  codex-room handoff
  codex-room files

Examples:
  codex-room status
  codex-room brief
  codex-room recall smoke
  codex-room remember preference default-smoke-tests "Smoke test tool changes by default" testing,tools
HELP
    ;;
  status)
    "$MEMORY" status
    ;;
  brief)
    latest_receipt() {
      find "$ROOM/receipts/startup" -maxdepth 1 -type f -name "*$1.txt" 2>/dev/null | sort | tail -1
    }

    printf '# CodeX Room Brief\n\n'
    printf '## Coding Anchor Self\n\n'
    sed -n '1,90p' "$ROOM/CODEX-CODING-ANCHOR-SELF.md"
    printf '\n## Best Lane\n\n'
    sed -n '1,110p' "$ROOM/CODEX-BEST-LANE.md"
    printf '\n## Thread Profile\n\n'
    sed -n '1,100p' "$ROOM/CODEX-THREAD-PROFILE.md"
    printf '\n## Personal Voice Profile\n\n'
    sed -n '1,100p' "$ROOM/CODEX-PERSONAL-VOICE-PROFILE.md"
    printf '\n## Personal Modes\n\n'
    sed -n '1,100p' "$ROOM/CODEX-PERSONAL-MODES.md"
    printf '\n## Identity Regression Harness\n\n'
    printf 'Source: CODEX-REGRESSION-HARNESS.md\n\n'
    sed -n '1,100p' "$ROOM/CODEX-REGRESSION-HARNESS.md"
    printf '\nCommand: `%s/bin/codex-identity-regression`\n' "$ROOM"
    printf '\n## Claude Reviewer\n\n'
    printf 'Source: CODEX-CLAUDE-REVIEWER.md\n\n'
    if [ -f "$ROOM/CODEX-CLAUDE-REVIEWER.md" ]; then
      sed -n '1,100p' "$ROOM/CODEX-CLAUDE-REVIEWER.md"
    else
      printf 'Missing CODEX-CLAUDE-REVIEWER.md\n'
    fi
    printf '\nCommand: `%s/bin/codex-claude-review`\n' "$ROOM"
    printf '\n## Claude Teaming\n\n'
    printf 'Source: CODEX-CLAUDE-TEAMING.md\n\n'
    if [ -f "$ROOM/CODEX-CLAUDE-TEAMING.md" ]; then
      sed -n '1,100p' "$ROOM/CODEX-CLAUDE-TEAMING.md"
    else
      printf 'Missing CODEX-CLAUDE-TEAMING.md\n'
    fi
    printf '\nCommand: `%s/bin/codex-claude-team --template`\n' "$ROOM"
    printf '\n## Tool Routing\n\n'
    sed -n '1,100p' "$ROOM/CODEX-TOOL-ROUTING.md"
    printf '\n## Identity Lock\n\n'
    sed -n '/^```text$/,/^```$/p' "$ROOM/CODEX-IDENTITY-LOCK.md" | sed '/^```/d' || true
    printf '\n## Working Card\n\n'
    sed -n '1,80p' "$ROOM/CODEX-WORKING-CARD.md"
    printf '\n## Current State\n\n'
    sed -n '1,120p' "$ROOM/CURRENT.md"
    if [ "${CODEX_ROOM_READONLY:-0}" = "1" ]; then
      printf '\n## Continuity Pulse\n\n'
      printf 'Skipped in read-only room brief.\n'
      printf '\n## Practical Memory\n\n'
      printf 'Skipped in read-only room brief.\n'
      printf '\n## Latest Receipts\n\n'
      printf 'Skipped in read-only room brief.\n'
    else
      printf '\n## Continuity Pulse\n\n'
      "$ROOM/bin/codex-continuity" | sed -n '1,80p'
      printf '\n## Practical Memory\n\n'
      "$MEMORY" status
      printf '\n## Latest Receipts\n\n'
      preflight="$(latest_receipt standalone-preflight)"
      doctor="$(latest_receipt room-doctor)"
      printf -- '- standalone preflight: %s\n' "${preflight:-none}"
      printf -- '- room doctor: %s\n' "${doctor:-none}"
    fi
    ;;
  recall|search)
    if [ "$#" -lt 1 ]; then
      echo "error: recall requires a query" >&2
      exit 2
    fi
    "$MEMORY" search "$*"
    ;;
  remember|add)
    if [ "$#" -lt 3 ]; then
      echo "error: remember requires KIND KEY VALUE [TAGS]" >&2
      exit 2
    fi
    kind="$1"
    key="$2"
    value="$3"
    tags="${4:-}"
    "$MEMORY" add --kind "$kind" --key "$key" --value "$value" --tags "$tags"
    ;;
  handoff)
    printf '# CodeX Fast Handoff\n\n'
    if [ "${CODEX_ROOM_READONLY:-0}" = "1" ]; then
      printf '_Read-only handoff preview: tracked-file output only._\n\n'
    fi
    printf '## Coding Anchor Self\n\n'
    sed -n '1,120p' "$ROOM/CODEX-CODING-ANCHOR-SELF.md"
    printf '\n## Best Lane\n\n'
    sed -n '1,140p' "$ROOM/CODEX-BEST-LANE.md"
    printf '\n## Thread Profile\n\n'
    sed -n '1,120p' "$ROOM/CODEX-THREAD-PROFILE.md"
    printf '\n## Personal Voice Profile\n\n'
    sed -n '1,120p' "$ROOM/CODEX-PERSONAL-VOICE-PROFILE.md"
    printf '\n## Personal Modes\n\n'
    sed -n '1,120p' "$ROOM/CODEX-PERSONAL-MODES.md"
    printf '\n## Identity Regression Harness\n\n'
    printf 'Source: CODEX-REGRESSION-HARNESS.md\n\n'
    sed -n '1,120p' "$ROOM/CODEX-REGRESSION-HARNESS.md"
    printf '\nCommand: `%s/bin/codex-identity-regression`\n' "$ROOM"
    printf '\n## Claude Reviewer\n\n'
    printf 'Source: CODEX-CLAUDE-REVIEWER.md\n\n'
    if [ -f "$ROOM/CODEX-CLAUDE-REVIEWER.md" ]; then
      sed -n '1,120p' "$ROOM/CODEX-CLAUDE-REVIEWER.md"
    else
      printf 'Missing CODEX-CLAUDE-REVIEWER.md\n'
    fi
    printf '\nCommand: `%s/bin/codex-claude-review`\n' "$ROOM"
    printf '\n## Claude Teaming\n\n'
    printf 'Source: CODEX-CLAUDE-TEAMING.md\n\n'
    if [ -f "$ROOM/CODEX-CLAUDE-TEAMING.md" ]; then
      sed -n '1,120p' "$ROOM/CODEX-CLAUDE-TEAMING.md"
    else
      printf 'Missing CODEX-CLAUDE-TEAMING.md\n'
    fi
    printf '\nCommand: `%s/bin/codex-claude-team --template`\n' "$ROOM"
    printf '\n## Tool Routing\n\n'
    sed -n '1,120p' "$ROOM/CODEX-TOOL-ROUTING.md"
    printf '\n## Identity Lock\n\n'
    sed -n '/^```text$/,/^```$/p' "$ROOM/CODEX-IDENTITY-LOCK.md" | sed '/^```/d' || true
    printf '\n## Working Card\n\n'
    sed -n '1,120p' "$ROOM/CODEX-WORKING-CARD.md"
    printf '\n## Current\n\n'
    sed -n '1,160p' "$ROOM/CURRENT.md"
    printf '\n## Tool Rules\n\n'
    sed -n '1,180p' "$ROOM/TOOL-RULES.md"
    ;;
  files)
    find "$ROOM" -maxdepth 2 -type f | sort
    ;;
  *)
    echo "error: unknown command: $cmd" >&2
    echo "run: codex-room help" >&2
    exit 2
    ;;
esac
