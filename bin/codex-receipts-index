#!/usr/bin/env python3
"""Build a plain index of CodeX work-note receipts."""
from __future__ import annotations

import argparse
import datetime as dt
from pathlib import Path


WORK_NOTES = Path("/Users/stephengodman/Candice-Code/work-notes")
INDEX = WORK_NOTES / "INDEX.md"


def title_for(path: Path) -> str:
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines()[:30]:
            line = line.strip()
            if line.startswith("# "):
                return line[2:].strip()
    except Exception:
        pass
    return path.stem.replace("-", " ")


def lane_for(name: str) -> str:
    if name.startswith("trello-"):
        return "Trello MCP"
    if name.startswith("codex-"):
        return "CodeX"
    if name.startswith("twilio-"):
        return "Twilio"
    if name.startswith("pool-") or "pool" in name:
        return "Pool Records"
    if "lmstudio" in name or "rag" in name:
        return "RAG"
    return "Other"


def build(limit: int) -> str:
    files = [p for p in WORK_NOTES.iterdir() if p.is_file() and p.name != "INDEX.md"]
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    rows = []
    for path in files[:limit]:
        modified = dt.datetime.fromtimestamp(path.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        rows.append((modified, lane_for(path.name), title_for(path), path.name))

    lines = [
        "# CodeX Work Notes Index",
        "",
        "Plain index of recent receipts. Newest first.",
        "",
        "| Modified | Lane | Receipt | File |",
        "|---|---|---|---|",
    ]
    for modified, lane, title, name in rows:
        safe_title = title.replace("|", "/")
        lines.append(f"| {modified} | {lane} | {safe_title} | `{name}` |")
    lines.append("")
    lines.append("Generated by `/Users/stephengodman/Candice-Code/bin/codex-receipts-index`.")
    return "\n".join(lines) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(description="Build work-notes/INDEX.md")
    parser.add_argument("--limit", type=int, default=120)
    parser.add_argument("--print", action="store_true", dest="print_only")
    args = parser.parse_args()
    text = build(max(1, args.limit))
    if args.print_only:
        print(text, end="")
    else:
        INDEX.write_text(text, encoding="utf-8")
        print(f"wrote: {INDEX}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
