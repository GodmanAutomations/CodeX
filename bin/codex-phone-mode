#!/usr/bin/env bash
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="$ROOT/.tmp"
CAFFEINATE_PID="$STATE_DIR/codex-phone-mode-caffeinate.pid"
CAFFEINATE_LABEL="com.codex.phone-mode.caffeinate"
CAFFEINATE_PLIST="$HOME/Library/LaunchAgents/$CAFFEINATE_LABEL.plist"
ANCHOR_ROOT="$ROOT/Coding Anchor Files/codex-coding-anchor"
ANCHOR_AGENTIC_CHECK="$ANCHOR_ROOT/bin/coding-anchor-agentic-check"
ANCHOR_DOCTOR="$ANCHOR_ROOT/bin/coding-anchor-doctor"
ANCHOR_BOOT="$ANCHOR_ROOT/bin/coding-anchor-boot"
CODEX_APP_OP="/Users/stephengodman/bin/codex-app-op"
PROFILE_CREDENTIALS="/Users/stephengodman/.claude/stephen-profile/credentials.md"
ONE_UNLOCK_LOADER="/Users/stephengodman/bin/codex-load-api-keys-once"
OP_ENV_FILE="${CODEX_OP_ENV_FILE:-/Users/stephengodman/.env.1password}"
PHONE_MODE_ENV="/Users/stephengodman/.codex-phone-mode.env"
OP_READ_TIMEOUT="${CODEX_PHONE_OP_READ_TIMEOUT:-3}"
ALLOW_BATTERY="${CODEX_PHONE_ALLOW_BATTERY:-0}"
PUSHOVER_PRIORITY="${CODEX_PUSHOVER_PRIORITY:--1}"
PUSHOVER_SOUND="${CODEX_PUSHOVER_SOUND:-none}"
STOP_CAFFEINATE_HELPER="/usr/local/sbin/codex-phone-mode-stop-caffeinate"

APPLY=0
STATUS=0
SUMMARY=0
NOTIFY=0
REFRESH_CACHE=0
NO_SLEEP=0
LID_CLOSED=1
RESTORE_SLEEP=0
SKIP_CREDENTIALS=0
REQUIRED_FAILURES=0

usage() {
  cat <<'USAGE'
Usage:
  /Users/stephengodman/CodeX/bin/codex-phone-mode --status
  /Users/stephengodman/CodeX/bin/codex-phone-mode --summary [--notify]
  /Users/stephengodman/CodeX/bin/codex-phone-mode --refresh-cache
  /Users/stephengodman/CodeX/bin/codex-phone-mode
  /Users/stephengodman/CodeX/bin/codex-phone-mode --apply [--notify] [--no-lid-closed] [--no-sleep-display] [--skip-credentials]
  /Users/stephengodman/CodeX/bin/codex-phone-mode --restore-sleep

Default is a dry-run preview. --apply enters phone/away mode.
--apply requests macOS disablesleep by default so Codex can survive lid close.
--summary prints a compact phone-readable readiness report.
--summary and --apply require AC power unless CODEX_PHONE_ALLOW_BATTERY=1 is set.
--notify sends the compact readiness report to Pushover when credentials exist.
Pushover notifications are silent by default: CODEX_PUSHOVER_PRIORITY=-1 and
CODEX_PUSHOVER_SOUND=none. Override those env vars only for audible alerts.
--refresh-cache resolves 1Password refs into the local 0600 phone cache.
USAGE
}

say() {
  printf '%s\n' "$*"
}

required_fail() {
  REQUIRED_FAILURES=$((REQUIRED_FAILURES + 1))
  say "REQUIRED_FAIL $*"
}

run_or_show() {
  if [[ "$APPLY" -eq 1 ]]; then
    "$@"
  else
    printf 'would run:'
    printf ' %q' "$@"
    printf '\n'
  fi
}

run_shell_or_show() {
  local desc="$1"
  shift
  if [[ "$APPLY" -eq 1 ]]; then
    "$@"
  else
    say "would $desc"
  fi
}

running_pidfile() {
  [[ -f "$CAFFEINATE_PID" ]] || return 1
  local pid
  pid="$(cat "$CAFFEINATE_PID" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  local command
  command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ "$command" == *"caffeinate -dimsu"* ]]
}

caffeinate_agent_pid() {
  launchctl print "gui/$(id -u)/$CAFFEINATE_LABEL" 2>/dev/null \
    | awk -F'= ' '/^[[:space:]]*pid = / {print $2; exit}'
}

phone_mode_caffeinate_pids() {
  local pid command
  pgrep -x caffeinate 2>/dev/null | while IFS= read -r pid; do
    command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
    if [[ "$command" == "/usr/bin/caffeinate -dimsu" ]]; then
      printf '%s\n' "$pid"
    fi
  done
}

write_caffeinate_agent() {
  mkdir -p "$HOME/Library/LaunchAgents"
  cat > "$CAFFEINATE_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$CAFFEINATE_LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-dimsu</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/codex-phone-mode-caffeinate.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/codex-phone-mode-caffeinate.log</string>
</dict>
</plist>
PLIST
  chmod 0600 "$CAFFEINATE_PLIST"
}

ensure_caffeinate() {
  mkdir -p "$STATE_DIR"
  if running_pidfile; then
    say "caffeinate: already active from phone-mode pid $(cat "$CAFFEINATE_PID")"
    return 0
  fi
  rm -f "$CAFFEINATE_PID"
  local agent_pid
  agent_pid="$(caffeinate_agent_pid)"
  if [[ -n "$agent_pid" ]]; then
    echo "$agent_pid" > "$CAFFEINATE_PID"
    say "caffeinate: already active from phone-mode launch agent pid $agent_pid"
    return 0
  fi
  if pgrep -x caffeinate >/dev/null 2>&1; then
    say "caffeinate: already active outside phone-mode"
    return 0
  fi
  if [[ "$APPLY" -eq 1 ]]; then
    write_caffeinate_agent
    launchctl bootstrap "gui/$(id -u)" "$CAFFEINATE_PLIST" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/$(id -u)/$CAFFEINATE_LABEL" >/dev/null 2>&1 || true
    sleep 1
    agent_pid="$(caffeinate_agent_pid)"
    if [[ -n "$agent_pid" ]]; then
      echo "$agent_pid" > "$CAFFEINATE_PID"
      say "caffeinate: started phone-mode launch agent pid $agent_pid"
    else
      say "caffeinate: launch agent requested but no pid reported"
    fi
  else
    say "would start phone-mode LaunchAgent for caffeinate -dimsu"
  fi
}

visible_apps() {
  osascript -e 'tell application "System Events" to get name of every process where background only is false' 2>/dev/null || true
}

power_status() {
  pmset -g batt 2>/dev/null || true
  pmset -g live 2>/dev/null | awk '/SleepDisabled|sleep |displaysleep / {print}' || true
}

current_power_source() {
  # pmset source names are ordinary strings like "AC Power" or "Battery Power".
  # If pmset is unavailable, callers treat the empty value as not-ac:unknown.
  pmset -g batt 2>/dev/null | sed -n "s/^Now drawing from '\\([^']*\\)'.*/\\1/p" || true
}

power_compact_status() {
  local source
  source="$(current_power_source)"
  if [[ "$ALLOW_BATTERY" == "1" ]]; then
    # override:unknown means the caller intentionally bypassed the AC guard
    # while pmset source detection was unavailable.
    printf 'override:%s' "${source:-unknown}"
    return 0
  fi
  if [[ "$source" == "AC Power" ]]; then
    printf 'OK:AC'
    return 0
  fi
  printf 'not-ac:%s' "${source:-unknown}"
  return 1
}

ensure_power_ready() {
  local summary
  if summary="$(power_compact_status)"; then
    say "power guard: $summary"
    return 0
  fi
  say "power guard: $summary"
  required_fail "AC power required for phone mode"
  return 1
}

credential_status() {
  "$ROOT/bin/codex-status" --skip-pi 2>/dev/null | sed -n '1,34p' || true
}

env_value() {
  local name="$1"
  local value="${!name-}"
  if [[ -z "$value" || "$value" == op://* ]]; then
    value="$(launchctl getenv "$name" 2>/dev/null || true)"
  fi
  printf '%s' "$value"
}

value_usable() {
  local value="$1"
  [[ -n "$value" && "$value" != op://* ]]
}

pushover_priority() {
  # Keep in sync with bin/codex-phone-mode-watchdog.
  case "$PUSHOVER_PRIORITY" in
    -2|-1|0|1)
      printf '%s' "$PUSHOVER_PRIORITY"
      ;;
    *)
      printf '%s' "-1"
      ;;
  esac
}

pushover_sound() {
  # Keep in sync with bin/codex-phone-mode-watchdog.
  if [[ "$PUSHOVER_SOUND" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]; then
    printf '%s' "$PUSHOVER_SOUND"
  else
    printf '%s' "none"
  fi
}

listener_status() {
  lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null \
    | awk 'NR==1 || $3=="stephengodman" {print}' \
    | sed -n '1,80p'
}

phone_env_cache_safe() {
  [[ -e "$PHONE_MODE_ENV" ]] || return 1
  local owner mode
  owner="$(stat -f '%Su' "$PHONE_MODE_ENV" 2>/dev/null || true)"
  mode="$(stat -f '%Lp' "$PHONE_MODE_ENV" 2>/dev/null || true)"
  [[ "$owner" == "$(id -un)" && "$mode" == "600" ]]
}

refresh_phone_cache() {
  say "credentials: refreshing phone cache from 1Password refs"
  say "credentials: target=$PHONE_MODE_ENV"
  if [[ -e "$PHONE_MODE_ENV" ]] && ! phone_env_cache_safe; then
    say "credentials: cache_unsafe=$PHONE_MODE_ENV"
    say "credentials: cache requires owner=$(id -un) and mode=0600"
    say "credentials: refusing to read or preserve unsafe cache"
    say "credentials: secrets_returned=false"
    return 1
  fi
  if ! command -v op >/dev/null 2>&1; then
    say "credentials: op cli missing"
    say "credentials: secrets_returned=false"
    return 1
  fi
  if [[ ! -r "$OP_ENV_FILE" ]]; then
    say "credentials: 1Password env file not readable: $OP_ENV_FILE"
    say "credentials: secrets_returned=false"
    return 1
  fi

  python3 - "$OP_ENV_FILE" "$PHONE_MODE_ENV" "$OP_READ_TIMEOUT" <<'PY'
import os
import subprocess
import sys
import tempfile
from pathlib import Path

op_env = Path(sys.argv[1])
phone_env = Path(sys.argv[2])
timeout = float(sys.argv[3])

def parse(path):
    values = {}
    order = []
    if not path.exists():
        return values, order
    for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        name, value = line.split("=", 1)
        if not name.replace("_", "A").isalnum() or name[0].isdigit():
            continue
        if name not in values:
            order.append(name)
        values[name] = value
    return values, order

op_values, op_order = parse(op_env)
cache_values, cache_order = parse(phone_env)

merged = {}
order = []
for name in cache_order + op_order:
    if name not in order:
        order.append(name)
for name in order:
    merged[name] = cache_values.get(name, op_values.get(name, ""))

resolved = []
kept = []
failed = []
op_unavailable = False

for name in order:
    value = merged.get(name, "")
    ref = None
    if value and not value.startswith("op://"):
        kept.append(name)
        continue
    if value.startswith("op://"):
        ref = value
    elif op_values.get(name, "").startswith("op://"):
        ref = op_values[name]
    if ref:
        if op_unavailable:
            failed.append(name)
            continue
        try:
            result = subprocess.run(
                ["op", "read", ref],
                check=False,
                capture_output=True,
                text=True,
                timeout=timeout,
            )
        except subprocess.TimeoutExpired:
            failed.append(name)
            op_unavailable = True
            continue
        if result.returncode == 0 and result.stdout.strip():
            merged[name] = result.stdout.strip()
            resolved.append(name)
        else:
            failed.append(name)

phone_env.parent.mkdir(parents=True, exist_ok=True)
fd, tmp_name = tempfile.mkstemp(prefix=phone_env.name + ".", dir=str(phone_env.parent))
try:
    os.fchmod(fd, 0o600)
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.write("# CodeX phone-mode resolved runtime cache. Do not commit.\n")
        for name in order:
            value = merged.get(name, "")
            if not value:
                continue
            value = value.replace("\r", "").replace("\n", "")
            fh.write(f"{name}={value}\n")
    os.replace(tmp_name, phone_env)
    os.chmod(phone_env, 0o600)
except Exception:
    try:
        os.unlink(tmp_name)
    except OSError:
        pass
    raise

for name, value in merged.items():
    if value and not value.startswith("op://"):
        subprocess.run(["/bin/launchctl", "setenv", name, value], check=True)

print("credentials: cache_resolved=" + " ".join(resolved))
print("credentials: cache_kept=" + str(len(kept)))
if failed:
    print("credentials: cache_unresolved=" + " ".join(failed))
print("credentials: secrets_returned=false")
raise SystemExit(0)
PY
}

codex_app_running() {
  pgrep -f '/Applications/Codex.app/Contents/MacOS/Codex|/Applications/Codex.app/Contents/Resources/codex app-server|Application Support/Codex' >/dev/null 2>&1
}

ensure_codex_app() {
  if codex_app_running; then
    say "Codex app: running"
    return 0
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if [[ -x "$CODEX_APP_OP" ]]; then
      "$CODEX_APP_OP" >/dev/null 2>&1 || true
      sleep 2
      if codex_app_running; then
        say "Codex app: launched"
      else
        say "Codex app: launch requested but not confirmed"
        required_fail "codex app not confirmed"
      fi
    else
      open -a Codex >/dev/null 2>&1 || true
      sleep 2
      if codex_app_running; then
        say "Codex app: launched with open"
      else
        say "Codex app: not confirmed"
        required_fail "codex app not confirmed"
      fi
    fi
  else
    say "would ensure Codex app is running"
  fi
}

anchor_status() {
  say "Coding Anchor readiness:"
  if [[ ! -d "$ANCHOR_ROOT" ]]; then
    say "anchor: missing $ANCHOR_ROOT"
    return 1
  fi
  if [[ -x "$ANCHOR_AGENTIC_CHECK" ]]; then
    if "$ANCHOR_AGENTIC_CHECK" >/dev/null 2>&1; then
      say "anchor agentic-check: pass"
    else
      say "anchor agentic-check: fail"
      return 1
    fi
  else
    say "anchor agentic-check: missing"
    return 1
  fi
  if [[ -x "$ANCHOR_DOCTOR" ]]; then
    local tmp
    tmp="$(mktemp "${TMPDIR:-/tmp}/coding-anchor-phone-doctor.XXXXXX")"
    if "$ANCHOR_DOCTOR" >"$tmp" 2>&1; then
      grep -E '^(RESULT|receipt:)' "$tmp" | sed 's/^/anchor doctor: /'
    else
      say "anchor doctor: fail"
      tail -12 "$tmp" | sed 's/^/  /'
      rm -f "$tmp"
      return 1
    fi
    rm -f "$tmp"
  else
    say "anchor doctor: missing"
    return 1
  fi
  if [[ -x "$ANCHOR_ROOT/bin/coding-anchor-next" ]]; then
    "$ANCHOR_ROOT/bin/coding-anchor-next" 2>&1 | sed 's/^/anchor next: /' || true
  fi
}

ensure_anchor_ready() {
  if [[ "$APPLY" -eq 1 ]]; then
    if ! anchor_status; then
      required_fail "Coding Anchor readiness failed"
    fi
  else
    say "would run Coding Anchor readiness: agentic-check, doctor, next-slice status"
  fi
}

print_status() {
  say "CodeX Phone Mode Status"
  say ""
  say "Power:"
  power_status
  say ""
  say "Codex app:"
  if codex_app_running; then
    say "running"
  else
    say "not confirmed"
  fi
  say ""
  say "Visible apps:"
  visible_apps
  say ""
  say "Credential readiness:"
  credential_status
  if [[ -e "$PHONE_MODE_ENV" ]]; then
    if phone_env_cache_safe; then
      say "phone-mode env cache: present mode=0600"
    else
      say "phone-mode env cache: unsafe permissions or owner; will refuse cache"
    fi
  else
    say "phone-mode env cache: missing; will use one-unlock loader or local profile fallback"
  fi
  say ""
  anchor_status
  say ""
  say "Listening services:"
  listener_status
  say ""
  say "Safety: secrets_returned=false"
}

load_runtime_credentials() {
  if [[ "$SKIP_CREDENTIALS" -eq 1 ]]; then
    say "credentials: skipped"
    return 0
  fi

  if [[ "$APPLY" -ne 1 ]]; then
    say "would preload runtime credentials from $PHONE_MODE_ENV, then 1Password/env path, with local profile fallback"
    return 0
  fi

  if [[ -e "$PHONE_MODE_ENV" ]]; then
    if ! phone_env_cache_safe; then
      say "credentials: cache_unsafe=$PHONE_MODE_ENV"
      say "credentials: cache requires owner=$(id -un) and mode=0600"
      say "credentials: refusing unsafe cache; using 1Password/env path or local profile fallback"
    elif [[ -r "$PHONE_MODE_ENV" ]]; then
    local loaded=()
    local skipped=()
    local deferred=()
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -n "$line" ]] || continue
      [[ "$line" != \#* ]] || continue
      [[ "$line" == *=* ]] || continue
      local name="${line%%=*}"
      local value="${line#*=}"
      if [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ && -n "$value" ]]; then
        if [[ "$value" == op://* ]]; then
          deferred+=("$name")
        else
          launchctl setenv "$name" "$value"
          loaded+=("$name")
        fi
      else
        skipped+=("$name")
      fi
    done < "$PHONE_MODE_ENV"
    say "credentials: cache_loaded=${loaded[*]}"
    if [[ "${#skipped[@]}" -gt 0 ]]; then
      say "credentials: cache_skipped=${skipped[*]}"
    fi
    if [[ "${#deferred[@]}" -gt 0 ]]; then
      say "credentials: cache_deferred_refs=${deferred[*]}"
      say "credentials: resolving deferred refs through 1Password/env path or local profile fallback"
    else
      say "credentials: secrets_returned=false"
      return 0
    fi
    fi
  fi

  if [[ -x "$ONE_UNLOCK_LOADER" ]]; then
    if /usr/bin/env PATH="/opt/homebrew/bin:$PATH" python3 - "$ONE_UNLOCK_LOADER" <<'PY' 2>/dev/null
import subprocess
import sys

cmd = [sys.argv[1]]
try:
    result = subprocess.run(cmd, check=False, capture_output=True, text=True, timeout=8)
except subprocess.TimeoutExpired:
    raise SystemExit(124)

if result.returncode == 0:
    print("credentials: 1Password loader completed")
    for line in (result.stdout or "").splitlines():
        if line.startswith(("loaded=", "missing=")):
            print("credentials: " + line)
    raise SystemExit(0)
raise SystemExit(result.returncode)
PY
    then
      say "credentials: secrets_returned=false"
      return 0
    fi
    say "credentials: 1Password loader unavailable or blocked; using local profile fallback"
  else
    say "credentials: one-unlock loader missing; using local profile fallback"
  fi

  if [[ ! -r "$PROFILE_CREDENTIALS" ]]; then
    say "credentials: local profile not readable"
    return 1
  fi

  python3 - "$PROFILE_CREDENTIALS" <<'PY'
from pathlib import Path
import re
import subprocess
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8", errors="replace")
sections = {}
current = None
for line in text.splitlines():
    if line.startswith("### "):
        current = line[4:].strip()
        sections[current] = []
    elif current:
        sections[current].append(line)

def field(section, label="API Key"):
    pattern = re.compile(r"- \*\*" + re.escape(label) + r":?\*\*\s*(.+)$")
    for line in sections.get(section, []):
        match = pattern.match(line)
        if not match:
            continue
        value = match.group(1).strip()
        if value and not value.startswith("["):
            return value
    return None

mapping = {
    "ANTHROPIC_API_KEY": ("Anthropic", "API Key"),
    "OPENAI_API_KEY": ("OpenAI", "API Key"),
    "BRAVE_SEARCH_API_KEY": ("Brave", "Search API Key (godman-automations)"),
    "CLOUDFLARE_API_TOKEN": ("Cloudflare API", "Ace Full Access (no IP restriction)"),
    "FIRECRAWL_API_KEY": ("Firecrawl", "API Key"),
    "GEMINI_API_KEY": ("Google / Gemini / GCP", "API Key"),
    "GODMAN_API_KEY": ("Godman Automations", "API Key"),
    "GOOGLE_API_KEY": ("Google / Gemini / GCP", "API Key"),
    "GOOGLE_GENERATIVE_AI_API_KEY": ("Google / Gemini / GCP", "API Key"),
    "GROQ_API_KEY": ("Groq", "API Key"),
    "LIVEKIT_API_KEY": ("LiveKit Cloud", "API Key"),
    "LMSTUDIO_API_KEY": ("LM Studio", "API Key"),
    "XAI_API_KEY": ("xAI", "API Key"),
}

loaded = []
missing = []
for env_name, (section, label) in mapping.items():
    value = field(section, label)
    if not value:
        missing.append(env_name)
        continue
    subprocess.run(["/bin/launchctl", "setenv", env_name, value], check=True)
    loaded.append(env_name)

print("credentials: loaded=" + ",".join(loaded))
if missing:
    print("credentials: missing=" + ",".join(missing))
print("credentials: secrets_returned=false")
PY
}

verify_runtime_credentials() {
  if [[ "$SKIP_CREDENTIALS" -eq 1 ]]; then
    say "credentials: required_env_check skipped"
    return 0
  fi

  if [[ "$APPLY" -ne 1 ]]; then
    say "would verify required API variables in launchctl user environment"
    return 0
  fi

  local required=(
    OPENAI_API_KEY
    ANTHROPIC_API_KEY
    GEMINI_API_KEY
    GOOGLE_API_KEY
    TRELLO_API_KEY
    TRELLO_TOKEN
    PUSHOVER_TOKEN
  )
  local missing=()
  local name value
  for name in "${required[@]}"; do
    value="$(launchctl getenv "$name" 2>/dev/null || true)"
    if ! value_usable "$value"; then
      missing+=("$name")
    fi
  done
  if ! value_usable "$(launchctl getenv PUSHOVER_USER_KEY 2>/dev/null || true)" \
    && ! value_usable "$(launchctl getenv PUSHOVER_USER 2>/dev/null || true)"; then
    missing+=("PUSHOVER_USER_KEY/PUSHOVER_USER")
  fi

  if [[ "${#missing[@]}" -gt 0 ]]; then
    say "credentials: required_missing=${missing[*]}"
    say "credentials: secrets_returned=false"
    return 1
  fi

  say "credentials: required_env=OK"
  say "credentials: secrets_returned=false"
}

required_credential_names() {
  printf '%s\n' \
    OPENAI_API_KEY \
    ANTHROPIC_API_KEY \
    GEMINI_API_KEY \
    GOOGLE_API_KEY \
    TRELLO_API_KEY \
    TRELLO_TOKEN \
    PUSHOVER_TOKEN
}

credential_compact_status() {
  local missing=()
  local name
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    if ! value_usable "$(env_value "$name")"; then
      missing+=("$name")
    fi
  done < <(required_credential_names)
  if ! value_usable "$(env_value PUSHOVER_USER_KEY)" \
    && ! value_usable "$(env_value PUSHOVER_USER)"; then
    missing+=("PUSHOVER_USER_KEY/PUSHOVER_USER")
  fi

  if [[ "${#missing[@]}" -gt 0 ]]; then
    printf 'missing:%s' "${missing[*]}"
    return 1
  fi
  printf 'OK'
}

cache_compact_status() {
  if [[ -e "$PHONE_MODE_ENV" ]]; then
    if phone_env_cache_safe; then
      printf 'OK:0600'
    else
      printf 'unsafe'
      return 1
    fi
  else
    printf 'missing'
    return 1
  fi
}

anchor_compact_status() {
  [[ -d "$ANCHOR_ROOT" ]] || { printf 'missing'; return 1; }
  [[ -x "$ANCHOR_AGENTIC_CHECK" ]] || { printf 'agentic-check-missing'; return 1; }
  "$ANCHOR_AGENTIC_CHECK" >/dev/null 2>&1 || { printf 'agentic-check-fail'; return 1; }
  [[ -x "$ANCHOR_DOCTOR" ]] || { printf 'doctor-missing'; return 1; }
  "$ANCHOR_DOCTOR" >/dev/null 2>&1 || { printf 'doctor-fail'; return 1; }
  printf 'OK'
}

phone_summary_body() {
  local failures=()
  local battery source sleep_disabled codex_status credential_summary cache_summary anchor_summary power_summary

  battery="$(pmset -g batt 2>/dev/null | awk 'NR==2 {gsub(/^[[:space:]]+/, ""); print}' || true)"
  source="$(current_power_source)"
  sleep_disabled="$(pmset -g live 2>/dev/null | awk '/SleepDisabled/ {print $2; exit}' || true)"
  power_summary="$(power_compact_status)" || failures+=("power")
  if codex_app_running; then
    codex_status="running"
  else
    codex_status="not-confirmed"
    failures+=("codex-app")
  fi
  credential_summary="$(credential_compact_status)" || failures+=("credentials")
  cache_summary="$(cache_compact_status)" || failures+=("env-cache")
  anchor_summary="$(anchor_compact_status)" || failures+=("anchor")
  if [[ "$sleep_disabled" != "1" ]]; then
    failures+=("lid-closed-sleep")
  fi

  say "CodeX Phone Summary"
  if [[ "${#failures[@]}" -eq 0 ]]; then
    say "ready: yes"
  else
    say "ready: no (${failures[*]})"
  fi
  say "power: ${source:-unknown}; ${battery:-battery unknown}"
  say "power_guard: $power_summary"
  say "lid_closed_sleep: $([[ "$sleep_disabled" == "1" ]] && echo disabled || echo not-disabled)"
  say "codex_app: $codex_status"
  say "credentials: $credential_summary"
  say "env_cache: $cache_summary"
  say "anchor: $anchor_summary"
  say "secrets_returned: false"

  [[ "${#failures[@]}" -eq 0 ]]
}

send_pushover() {
  local title="$1"
  local message="$2"
  local token user priority sound
  token="$(env_value PUSHOVER_TOKEN)"
  user="$(env_value PUSHOVER_USER_KEY)"
  priority="$(pushover_priority)"
  sound="$(pushover_sound)"
  if [[ -z "$user" ]]; then
    user="$(env_value PUSHOVER_USER)"
  fi
  if ! value_usable "$token" || ! value_usable "$user"; then
    say "pushover: missing PUSHOVER_TOKEN or PUSHOVER_USER_KEY/PUSHOVER_USER"
    say "pushover: secrets_returned=false"
    return 1
  fi
  if curl -fsS \
    --form-string "token=$token" \
    --form-string "user=$user" \
    --form-string "title=$title" \
    --form-string "message=$message" \
    --form-string "priority=$priority" \
    --form-string "sound=$sound" \
    https://api.pushover.net/1/messages.json >/dev/null; then
    say "pushover: sent silent priority=$priority sound=$sound"
    say "pushover: secrets_returned=false"
    return 0
  fi
  say "pushover: send failed"
  say "pushover: secrets_returned=false"
  return 1
}

notify_phone_summary() {
  local title="$1"
  local tmp body
  tmp="$(mktemp "${TMPDIR:-/tmp}/codex-phone-summary.XXXXXX")"
  phone_summary_body >"$tmp"
  body="$(cat "$tmp")"
  rm -f "$tmp"
  send_pushover "$title" "$body"
}

quit_low_risk_apps() {
  local apps=(
    "Messages"
    "Mail"
    "Calendar"
    "Contacts"
    "Music"
    "TV"
    "Podcasts"
    "Photos"
    "Safari"
    "Google Chrome"
    "LM Studio"
  )
  local app
  for app in "${apps[@]}"; do
    if [[ "$APPLY" -eq 1 ]]; then
      osascript >/dev/null 2>&1 <<APPLESCRIPT || true
try
  if application "$app" is running then
    ignoring application responses
      tell application "$app" to quit
    end ignoring
  end if
end try
APPLESCRIPT
    else
      say "would quit low-risk app if running: $app"
    fi
  done
}

hide_document_apps() {
  if [[ "$APPLY" -eq 1 ]]; then
    osascript >/dev/null 2>&1 <<'APPLESCRIPT' || true
try
  tell application "System Events"
    set visible of every application process whose background only is false and name is not "Codex" to false
  end tell
end try
try
  tell application "Finder" to close every window
end try
APPLESCRIPT
  else
    say "would hide non-Codex visible apps and close Finder windows"
  fi
}

stop_launchagent_plists() {
  local uid
  uid="$(id -u)"
  local plists=(
    "$HOME/Library/LaunchAgents/com.godman.sillytavern.plist"
    "$HOME/Library/LaunchAgents/com.rook.telegram.plist"
    "$HOME/Library/LaunchAgents/com.godman.lmstudio-headless.plist"
    "$HOME/Library/LaunchAgents/com.godman.comfyui.venice.plist"
    "$HOME/Library/LaunchAgents/homebrew.mxcl.ollama.plist"
    "$HOME/Library/LaunchAgents/homebrew.mxcl.redis.plist"
    "$HOME/Library/LaunchAgents/homebrew.mxcl.postgresql@16.plist"
  )
  local plist
  for plist in "${plists[@]}"; do
    [[ -f "$plist" ]] || continue
    run_or_show launchctl bootout "gui/$uid" "$plist" 2>/dev/null || true
  done
}

stop_known_processes() {
  if [[ "$APPLY" -eq 1 ]]; then
    pkill -TERM -f '/Users/stephengodman/Applications/SillyTavern/.*server\.js|/Users/stephengodman/.nvm/versions/node/.*/bin/node server\.js' 2>/dev/null || true
    pkill -TERM -f 'rook_telegram_bot\.py' 2>/dev/null || true
    pkill -TERM -f '/Applications/LM Studio\.app/Contents/MacOS/LM Studio' 2>/dev/null || true
    pkill -TERM -f '/Users/stephengodman/Rook/venice/ComfyUI/main\.py' 2>/dev/null || true
    pkill -TERM -f 'ollama serve' 2>/dev/null || true
    pkill -TERM -f 'redis-server 127\.0\.0\.1:6379' 2>/dev/null || true
    pkill -TERM -f 'postgres -D /opt/homebrew/var/postgresql@16' 2>/dev/null || true
  else
    say "would stop known non-phone processes: SillyTavern, Rook Telegram, LM Studio, ComfyUI/Venice, Ollama, Redis, Postgres"
  fi
}

apply_privacy_power_posture() {
  if [[ "$APPLY" -eq 1 ]]; then
    osascript >/dev/null 2>&1 <<'APPLESCRIPT' || true
set volume output muted true
set volume alert volume 0
APPLESCRIPT
    defaults write com.apple.screensaver askForPassword -int 1
    defaults write com.apple.screensaver askForPasswordDelay -int 0
    osascript -e 'get volume settings' 2>/dev/null || true
    osascript -e 'tell application "System Events" to keystroke "q" using {control down, command down}' >/dev/null 2>&1 || true
    if [[ "$NO_SLEEP" -eq 0 ]]; then
      /usr/bin/pmset displaysleepnow || true
    fi
  else
    say "would mute output, set alert volume to 0, require password immediately, lock screen, and sleep display"
  fi
}

sudo_pmset() {
  sudo -n "$@" >/dev/null 2>&1 && return 0
  say "sudo: unavailable non-interactively; lid-closed sleep disable was not changed"
  say "sudo: install or unlock scoped pmset permission for lid-closed survival"
  return 1
}

enable_lid_closed_survival() {
  if [[ "$APPLY" -eq 1 ]]; then
    if sudo_pmset /usr/bin/pmset -a disablesleep 1; then
      say "lid-closed survival: enabled with pmset disablesleep=1"
    else
      say "lid-closed survival: blocked at sudo"
      required_fail "lid-closed survival blocked"
    fi
  else
    say "would enable lid-closed survival: sudo /usr/bin/pmset -a disablesleep 1"
  fi
}

restore_sleep() {
  say "CodeX phone/away mode sleep restore"
  if sudo_pmset /usr/bin/pmset -a disablesleep 0; then
    say "lid-closed survival: restored disablesleep=0"
  fi
  if launchctl print "gui/$(id -u)/$CAFFEINATE_LABEL" >/dev/null 2>&1; then
    launchctl bootout "gui/$(id -u)/$CAFFEINATE_LABEL" >/dev/null 2>&1 || true
    sleep 1
    say "caffeinate: stopped phone-mode launch agent"
  fi
  rm -f "$CAFFEINATE_PLIST"
  if running_pidfile; then
    local pid
    pid="$(cat "$CAFFEINATE_PID" 2>/dev/null || true)"
    if [[ -n "$pid" ]]; then
      kill "$pid" 2>/dev/null || true
      sleep 1
      rm -f "$CAFFEINATE_PID"
      say "caffeinate: stopped phone-mode pid $pid"
    fi
  else
    local pids
    pids="$(phone_mode_caffeinate_pids)"
    if [[ -n "$pids" ]]; then
      while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue
        kill "$pid" 2>/dev/null || true
        if kill -0 "$pid" 2>/dev/null; then
          if [[ -x "$STOP_CAFFEINATE_HELPER" ]] && sudo -n "$STOP_CAFFEINATE_HELPER" >/dev/null 2>&1; then
            :
          fi
        fi
        sleep 1
        if kill -0 "$pid" 2>/dev/null; then
          say "caffeinate: persistent pid $pid still running"
        else
          say "caffeinate: stopped persistent pid $pid"
        fi
      done <<< "$pids"
    fi
  fi
  rm -f "$CAFFEINATE_PID"
  print_status
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --apply)
      APPLY=1
      ;;
    --status)
      STATUS=1
      ;;
    --summary)
      SUMMARY=1
      ;;
    --notify)
      NOTIFY=1
      ;;
    --refresh-cache)
      REFRESH_CACHE=1
      ;;
    --no-sleep-display)
      NO_SLEEP=1
      ;;
    --skip-credentials)
      SKIP_CREDENTIALS=1
      ;;
    --lid-closed)
      LID_CLOSED=1
      ;;
    --no-lid-closed)
      LID_CLOSED=0
      ;;
    --restore-sleep)
      RESTORE_SLEEP=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if [[ "$RESTORE_SLEEP" -eq 1 ]]; then
  restore_sleep
  exit 0
fi

if [[ "$REFRESH_CACHE" -eq 1 ]]; then
  refresh_phone_cache
  refresh_rc=$?
  APPLY=1
  if ! load_runtime_credentials; then
    required_fail "runtime credential preload failed"
  fi
  if ! verify_runtime_credentials; then
    required_fail "runtime credential readiness failed"
  fi
  phone_summary_body
  if [[ "$refresh_rc" -ne 0 || "$REQUIRED_FAILURES" -gt 0 ]]; then
    exit 1
  fi
  exit 0
fi

if [[ "$STATUS" -eq 1 ]]; then
  print_status
  if [[ "$NOTIFY" -eq 1 ]]; then
    notify_phone_summary "CodeX phone status" || exit 1
  fi
  exit 0
fi

if [[ "$SUMMARY" -eq 1 ]]; then
  summary_tmp="$(mktemp "${TMPDIR:-/tmp}/codex-phone-summary.XXXXXX")"
  # phone_summary_body returns non-zero when any readiness failure exists,
  # including the default AC-power guard.
  phone_summary_body >"$summary_tmp"
  summary_rc=$?
  cat "$summary_tmp"
  if [[ "$NOTIFY" -eq 1 ]]; then
    summary_body="$(cat "$summary_tmp")"
    if ! send_pushover "CodeX phone summary" "$summary_body"; then
      rm -f "$summary_tmp"
      exit 1
    fi
  fi
  rm -f "$summary_tmp"
  exit "$summary_rc"
fi

if [[ "$NOTIFY" -eq 1 && "$APPLY" -ne 1 ]]; then
  usage >&2
  exit 2
fi

say "CodeX phone/away mode"
say "mode: $([[ "$APPLY" -eq 1 ]] && echo apply || echo dry-run)"
say ""
say "Keeps: Codex, iTerm, Tailscale, Cloudflare tunnel, Unified Remote, CodeX MCP helpers, photo bridge."
say "Stops: obvious user apps and heavy/unrelated local stacks."
say "Secrets: load the local phone-mode env cache and existing credential paths; never commit values."
say "Anchor: verify Coding Anchor agentic-check, doctor, and next-slice state for phone use."
if [[ "$LID_CLOSED" -eq 1 ]]; then
  say "Lid closed: request pmset disablesleep=1 even on battery/portable power."
fi
say ""

if [[ "$APPLY" -eq 1 ]]; then
  # Keep this guard before any keep-awake or pmset mutation in apply mode.
  if ! ensure_power_ready; then
    say "Phone mode blocked before keep-awake changes because AC power is required."
    exit 1
  fi
fi
ensure_caffeinate
ensure_codex_app
if [[ "$LID_CLOSED" -eq 1 ]]; then
  enable_lid_closed_survival
fi
if ! load_runtime_credentials; then
  required_fail "runtime credential preload failed"
fi
if ! verify_runtime_credentials; then
  required_fail "runtime credential readiness failed"
fi
ensure_anchor_ready
quit_low_risk_apps
hide_document_apps
stop_launchagent_plists
stop_known_processes
sleep 2
apply_privacy_power_posture

say ""
print_status

if [[ "$NOTIFY" -eq 1 ]]; then
  if [[ "$REQUIRED_FAILURES" -gt 0 ]]; then
    notify_phone_summary "CodeX phone mode failed" || required_fail "phone notification failed"
  else
    notify_phone_summary "CodeX phone mode ready" || required_fail "phone notification failed"
  fi
fi

if [[ "$APPLY" -eq 1 && "$REQUIRED_FAILURES" -gt 0 ]]; then
  say ""
  say "Phone mode required failures: $REQUIRED_FAILURES"
  exit 1
fi
