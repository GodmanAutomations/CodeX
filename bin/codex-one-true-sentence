#!/usr/bin/env bash
set -euo pipefail

ROOT="/Users/stephengodman/CodeX"
SENTENCE_FILE="$ROOT/continuity/one-true-sentence.txt"
STAMP_FILE="$ROOT/continuity/one-true-sentence.timestamp"
STAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
MIN_INTERVAL_SECONDS=$((24 * 60 * 60))
FORCE=0

if [[ "${1:-}" == "--force" ]]; then
  FORCE=1
  shift
fi

TEXT=${*:-}

if [[ -z "$TEXT" ]]; then
  echo "usage: codex-one-true-sentence [--force] <sentence>" >&2
  exit 2
fi

if [[ "$FORCE" -ne 1 && -f "$STAMP_FILE" ]]; then
  LAST_STAMP=$(cat "$STAMP_FILE")
  SECONDS_SINCE=$(/usr/bin/python3 - "$LAST_STAMP" "$STAMP" <<'PY'
from datetime import datetime, timezone
import sys

try:
    last = datetime.strptime(sys.argv[1], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    now = datetime.strptime(sys.argv[2], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
except ValueError:
    print(999999999)
else:
    print(int((now - last).total_seconds()))
PY
)
  if [[ "$SECONDS_SINCE" -lt "$MIN_INTERVAL_SECONDS" ]]; then
    echo "one true sentence is a carry-forward line, not a session log" >&2
    echo "last update: $LAST_STAMP" >&2
    echo "use --force only for a meaningful same-day shift" >&2
    exit 3
  fi
fi

TEXT=$(printf '%s' "$TEXT" | perl -pe 's/VENICE_(ADMIN|API)_KEY_[A-Za-z0-9_-]+/[REDACTED_VENICE_KEY]/g; s/sk-[A-Za-z0-9_-]{20,}/[REDACTED_API_KEY]/g; s/ghp_[A-Za-z0-9_]{20,}/[REDACTED_GITHUB_TOKEN]/g; s/github_pat_[A-Za-z0-9_]{20,}/[REDACTED_GITHUB_TOKEN]/g; s/(api[_-]?key|token|secret|password)\s*[:=]\s*[^\s"'"'"']+/\1=[REDACTED_SECRET]/ig')

printf '%s\n' "$TEXT" > "$SENTENCE_FILE"
printf '%s\n' "$STAMP" > "$STAMP_FILE"

/Users/stephengodman/CodeX/bin/codex-private-journal "One True Sentence ($STAMP): $TEXT" >/dev/null

chmod 600 "$SENTENCE_FILE" "$STAMP_FILE"
printf 'one true sentence saved: %s\n' "$SENTENCE_FILE"
