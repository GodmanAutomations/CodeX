#!/usr/bin/env python3
"""One plain MCP control surface for CodeX."""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path("/Users/stephengodman/CodeX")
TRELLO_LAUNCHER = ROOT / "mcp_servers" / "trello_mcp_launcher.sh"
TRELLO_SERVER = ROOT / "mcp_servers" / "trello_mcp_server.py"
RECON_LAUNCHER = ROOT / "mcp_servers" / "recon_mcp_launcher.sh"
RECON_SERVER = ROOT / "mcp_servers" / "recon_mcp_server.py"
RECON_RATES = ROOT / "config" / "stephen-billing-rates.json"
ENV_LOADER = Path("/Users/stephengodman/bin/codex-load-api-keys-once")
TRELLO_FIND = ROOT / "bin" / "trello-find-card"
TREE_STEWARD = ROOT / "bin" / "codex-tree-steward"

WRITE_PREFIXES = (
    "create_",
    "update_",
    "move_",
    "archive_",
    "add_",
    "attach_",
    "set_",
    "write_",
    "apply_",
    "publish_",
    "copy_",
    "draft_",
    "prepare_",
    "download_",
    "export_",
)

WRITE_TOOL_NAMES = {
    "sync_pool_photos_to_board",
}

LOCAL_FILE_WRITE_PREFIXES = (
    "download_",
    "draft_",
    "prepare_",
    "export_",
)


def run(cmd: list[str], timeout: int = 30) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=False, capture_output=True, text=True, timeout=timeout)


def json_command(cmd: list[str], timeout: int = 30) -> dict[str, Any]:
    try:
        result = run(cmd, timeout=timeout)
    except Exception as exc:
        return {"ok": False, "error": str(exc), "returncode": 1}
    output = result.stdout.strip() or result.stderr.strip()
    try:
        payload = json.loads(output)
    except Exception:
        payload = {"ok": False, "error": output[:1200] or f"exit {result.returncode}"}
    payload.setdefault("returncode", result.returncode)
    return payload


def mcp_tools(server_path: Path, server_name: str) -> list[dict[str, str]]:
    if not server_path.exists():
        return []
    text = server_path.read_text(encoding="utf-8", errors="replace")
    names = re.findall(r"(?m)^@mcp\.tool\(\)\n(?:.+\n)*?def\s+([A-Za-z_][A-Za-z0-9_]*)\(", text)
    tools = []
    for name in names:
        risk = "writes" if name.startswith(WRITE_PREFIXES) or name in WRITE_TOOL_NAMES else "read-only"
        if name.startswith(LOCAL_FILE_WRITE_PREFIXES):
            risk = "local-file-write"
        tools.append({"server": server_name, "name": name, "risk": risk})
    return tools


def trello_tools() -> list[dict[str, str]]:
    return mcp_tools(TRELLO_SERVER, "trello")


def recon_tools() -> list[dict[str, str]]:
    return mcp_tools(RECON_SERVER, "recon")


def recon_rate_source() -> dict[str, Any]:
    if not RECON_RATES.exists():
        return {"ok": False, "rate_file_path": str(RECON_RATES), "error": "missing"}
    try:
        payload = json.loads(RECON_RATES.read_text(encoding="utf-8"))
    except Exception as exc:
        return {"ok": False, "rate_file_path": str(RECON_RATES), "error": str(exc)}
    addons = payload.get("addons") or {}
    addon_rule_count = sum(len(value) for value in addons.values() if isinstance(value, list))
    distance_premiums = payload.get("distance_premiums") or []
    return {
        "ok": True,
        "source": payload.get("source"),
        "source_path": payload.get("source_path"),
        "version": payload.get("version"),
        "rate_file_path": str(RECON_RATES),
        "base_count": len(payload.get("base") or {}),
        "addon_group_count": len(addons),
        "addon_rule_count": addon_rule_count,
        "distance_premium_count": len(distance_premiums),
    }


def print_status(json_mode: bool) -> int:
    trello = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    recon = json_command([str(RECON_LAUNCHER), "--status"], timeout=20)
    rates = recon_rate_source()
    payload = {
        "ok": bool(trello.get("ok")) and bool(recon.get("ok")),
        "trello": trello,
        "recon": recon,
        "recon_rates": rates,
        "safety": {"secrets_returned": False},
    }
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX MCP Status")
        print("")
        print(f"Trello: {'OK' if trello.get('ok') else 'NO'}")
        print(f"Credential source: {trello.get('credential_source') or 'unknown'}")
        op_status = (trello.get("op_resolution") or {}).get("status") or "unknown"
        print(f"1Password fallback: {op_status}")
        print(f"Launcher: {trello.get('paths', {}).get('launcher_mode')}")
        print(f"Server exists: {trello.get('paths', {}).get('server_exists')}")
        print("")
        print(f"Recon: {'OK' if recon.get('ok') else 'NO'}")
        print(f"Data root: {recon.get('data_root') or 'unknown'}")
        print(f"Reports: {(recon.get('reports') or {}).get('count', 0)}")
        print(f"Stale path warnings: {len(recon.get('stale_path_warnings') or [])}")
        print(f"Rate source: {rates.get('source_path') or rates.get('source') or 'unknown'}")
        print(f"Base rates: {rates.get('base_count', 0)}")
        print(f"Add-on groups: {rates.get('addon_group_count', 0)}")
        print(f"Add-on rules: {rates.get('addon_rule_count', 0)}")
        print(f"Distance premiums: {rates.get('distance_premium_count', 0)}")
    return 0 if payload.get("ok") else 1


def compact_trello_status(payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "ok": bool(payload.get("ok")),
        "credential_source": payload.get("credential_source"),
        "op_status": (payload.get("op_resolution") or {}).get("status"),
        "launcher_mode": (payload.get("paths") or {}).get("launcher_mode"),
        "server_exists": (payload.get("paths") or {}).get("server_exists"),
        "error": payload.get("error"),
    }


def compact_recon_status(payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "ok": bool(payload.get("ok")),
        "data_root": payload.get("data_root"),
        "reports_count": (payload.get("reports") or {}).get("count"),
        "stale_path_warnings": len(payload.get("stale_path_warnings") or []),
        "error": payload.get("error"),
    }


def preflight(json_mode: bool) -> int:
    tree = json_command(
        [str(TREE_STEWARD), "--json", "--preflight", "trello-mcp", "--no-receipt"],
        timeout=20,
    )
    trello = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    recon = json_command([str(RECON_LAUNCHER), "--status"], timeout=20)
    payload = {
        "ok": bool(tree.get("strict_pass")) and bool(trello.get("ok")) and bool(recon.get("ok")),
        "tree": {
            "ok": bool(tree.get("strict_pass")),
            "dirty_count": tree.get("dirty_count"),
            "strict_pass": tree.get("strict_pass"),
            "strict_blockers": tree.get("strict_blockers"),
            "summary": tree.get("summary") or {},
            "findings_count": len(tree.get("findings") or []),
            "ignored_advisories_count": len(tree.get("ignored_advisories") or []),
            "block_findings": [
                item for item in (tree.get("findings") or []) if item.get("severity") == "block"
            ],
            "policy_path": tree.get("policy_path"),
        },
        "trello": compact_trello_status(trello),
        "recon": compact_recon_status(recon),
        "safety": {
            "secrets_returned": False,
            "trello_writes": False,
            "git_writes": False,
            "file_deletes": False,
        },
    }
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX MCP Preflight")
        print("")
        print(f"Status: {'OK' if payload.get('ok') else 'NO'}")
        print(f"Tree strict pass: {'OK' if payload['tree'].get('strict_pass') else 'NO'}")
        print(f"Dirty count: {payload['tree'].get('dirty_count')}")
        print(f"Tree blockers: {payload['tree'].get('strict_blockers')}")
        print(f"Policy findings: {payload['tree'].get('findings_count')}")
        print(f"Ignored advisories: {payload['tree'].get('ignored_advisories_count')}")
        print(f"Trello: {'OK' if trello.get('ok') else 'NO'}")
        print(f"Trello credential source: {trello.get('credential_source') or 'unknown'}")
        print(f"Recon: {'OK' if recon.get('ok') else 'NO'}")
        if not payload.get("ok"):
            print("")
            print("Blocked: read the tree-steward receipt/output before Trello MCP edits.")
    return 0 if payload.get("ok") else 1


def print_tools(json_mode: bool, writes: bool) -> int:
    tools = trello_tools() + recon_tools()
    if not writes:
        tools = [tool for tool in tools if tool["risk"] == "read-only"]
    if json_mode:
        print(json.dumps({"ok": True, "count": len(tools), "tools": tools}, indent=2, sort_keys=True))
    else:
        by_server: dict[str, list[dict[str, str]]] = {}
        for tool in tools:
            by_server.setdefault(tool["server"], []).append(tool)
        print(f"CodeX MCP tools: {len(tools)}")
        print("")
        for server, server_tools in sorted(by_server.items()):
            print(f"{server}: {len(server_tools)}")
            for tool in server_tools:
                print(f"- {tool['name']} ({tool['risk']})")
            print("")
    return 0


def trello_test(query: str, json_mode: bool) -> int:
    payload = json_command([str(TRELLO_FIND), "--json", query], timeout=30)
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    elif payload.get("ok"):
        cards = payload.get("cards") or []
        print(f"Trello card search OK: {len(cards)} result(s) for {query}")
        for card in cards[:5]:
            print(f"- {card.get('name')} | {card.get('shortUrl')}")
    else:
        print(f"Trello card search failed: {payload.get('error') or 'unknown error'}")
    return 0 if payload.get("ok") else 1


def doctor(live: bool, json_mode: bool) -> int:
    flag = "--doctor-live" if live else "--doctor"
    trello_status = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    trello_diagnostic = json_command([str(TRELLO_LAUNCHER), flag], timeout=45)
    recon = json_command([str(RECON_LAUNCHER), "--status"], timeout=20)
    payload = {
        "ok": bool(trello_status.get("ok")) and bool(recon.get("ok")),
        "trello": trello_status,
        "trello_diagnostic": trello_diagnostic,
        "recon": recon,
        "safety": {"secrets_returned": False},
    }
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        runtime = trello_diagnostic.get("launcher_runtime") or trello_status
        print("CodeX MCP Doctor")
        print("")
        print(f"Status: {'OK' if payload.get('ok') else 'NO'}")
        print(f"Credential source: {runtime.get('credential_source') or 'unknown'}")
        print(f"1Password: {(runtime.get('op_resolution') or {}).get('status') or 'unknown'}")
        print(f"Recon: {'OK' if recon.get('ok') else 'NO'}")
        print(f"Recon data root: {recon.get('data_root') or 'unknown'}")
        print(f"Recon stale path warnings: {len(recon.get('stale_path_warnings') or [])}")
        rec = trello_diagnostic.get("recommendation")
        if rec:
            print(f"Recommendation: {rec}")
    return 0 if payload.get("ok") else 1


def reload_env(json_mode: bool) -> int:
    result = run([str(ENV_LOADER)], timeout=60)
    status = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    recon = json_command([str(RECON_LAUNCHER), "--status"], timeout=20)
    payload = {
        "ok": result.returncode == 0 and bool(status.get("ok")) and bool(recon.get("ok")),
        "env_loader_output": (result.stdout or result.stderr).strip(),
        "trello_status": status,
        "recon_status": recon,
        "note": "Codex app may need a restart for MCP tool-list changes; API env is refreshed now.",
        "safety": {"secrets_returned": False},
    }
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX MCP reload")
        print("")
        print(payload["env_loader_output"] or f"env loader exit {result.returncode}")
        print(f"Trello credential source: {status.get('credential_source') or 'unknown'}")
        print(f"Recon data root: {recon.get('data_root') or 'unknown'}")
        print(payload["note"])
    return 0 if payload["ok"] else 1


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="CodeX MCP control panel")
    parser.add_argument("--json", action="store_true")
    sub = parser.add_subparsers(dest="command", required=True)
    status = sub.add_parser("status")
    status.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    preflight_parser = sub.add_parser("preflight")
    preflight_parser.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    tools = sub.add_parser("tools")
    tools.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    tools.add_argument("--include-writes", action="store_true")
    test = sub.add_parser("trello-test")
    test.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    test.add_argument("query", nargs="?", default="Byrd")
    doc = sub.add_parser("doctor")
    doc.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    doc.add_argument("--live", action="store_true")
    reload_parser = sub.add_parser("reload")
    reload_parser.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    args = parser.parse_args(argv)

    if args.command == "status":
        return print_status(args.json)
    if args.command == "preflight":
        return preflight(args.json)
    if args.command == "tools":
        return print_tools(args.json, args.include_writes)
    if args.command == "trello-test":
        return trello_test(args.query, args.json)
    if args.command == "doctor":
        return doctor(args.live, args.json)
    if args.command == "reload":
        return reload_env(args.json)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
