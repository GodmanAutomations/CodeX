#!/usr/bin/env python3
"""One plain MCP control surface for CodeX."""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path
from typing import Any


ROOT = Path("/Users/stephengodman/Candice-Code")
TRELLO_LAUNCHER = ROOT / "mcp_servers" / "trello_mcp_launcher.sh"
TRELLO_SERVER = ROOT / "mcp_servers" / "trello_mcp_server.py"
ENV_LOADER = Path("/Users/stephengodman/bin/codex-load-api-keys-once")
TRELLO_FIND = ROOT / "bin" / "trello-find-card"

WRITE_PREFIXES = (
    "create_",
    "update_",
    "move_",
    "archive_",
    "add_",
    "attach_",
    "set_",
    "write_",
    "apply_",
    "copy_",
    "download_",
)


def run(cmd: list[str], timeout: int = 30) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=False, capture_output=True, text=True, timeout=timeout)


def json_command(cmd: list[str], timeout: int = 30) -> dict[str, Any]:
    try:
        result = run(cmd, timeout=timeout)
    except Exception as exc:
        return {"ok": False, "error": str(exc), "returncode": 1}
    output = result.stdout.strip() or result.stderr.strip()
    try:
        payload = json.loads(output)
    except Exception:
        payload = {"ok": False, "error": output[:1200] or f"exit {result.returncode}"}
    payload.setdefault("returncode", result.returncode)
    return payload


def trello_tools() -> list[dict[str, str]]:
    if not TRELLO_SERVER.exists():
        return []
    text = TRELLO_SERVER.read_text(encoding="utf-8", errors="replace")
    names = re.findall(r"(?m)^@mcp\.tool\(\)\n(?:.+\n)*?def\s+([A-Za-z_][A-Za-z0-9_]*)\(", text)
    tools = []
    for name in names:
        risk = "writes" if name.startswith(WRITE_PREFIXES) else "read-only"
        if name.startswith("download_"):
            risk = "local-file-write"
        tools.append({"name": name, "risk": risk})
    return tools


def print_status(json_mode: bool) -> int:
    payload = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX MCP Status")
        print("")
        print(f"Trello: {'OK' if payload.get('ok') else 'NO'}")
        print(f"Credential source: {payload.get('credential_source') or 'unknown'}")
        op_status = (payload.get("op_resolution") or {}).get("status") or "unknown"
        print(f"1Password fallback: {op_status}")
        print(f"Launcher: {payload.get('paths', {}).get('launcher_mode')}")
        print(f"Server exists: {payload.get('paths', {}).get('server_exists')}")
    return 0 if payload.get("ok") else 1


def print_tools(json_mode: bool, writes: bool) -> int:
    tools = trello_tools()
    if not writes:
        tools = [tool for tool in tools if tool["risk"] == "read-only"]
    if json_mode:
        print(json.dumps({"ok": True, "count": len(tools), "tools": tools}, indent=2, sort_keys=True))
    else:
        print(f"Trello MCP tools: {len(tools)}")
        print("")
        for tool in tools:
            print(f"- {tool['name']} ({tool['risk']})")
    return 0


def trello_test(query: str, json_mode: bool) -> int:
    payload = json_command([str(TRELLO_FIND), "--json", query], timeout=30)
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    elif payload.get("ok"):
        cards = payload.get("cards") or []
        print(f"Trello card search OK: {len(cards)} result(s) for {query}")
        for card in cards[:5]:
            print(f"- {card.get('name')} | {card.get('shortUrl')}")
    else:
        print(f"Trello card search failed: {payload.get('error') or 'unknown error'}")
    return 0 if payload.get("ok") else 1


def doctor(live: bool, json_mode: bool) -> int:
    flag = "--doctor-live" if live else "--doctor"
    payload = json_command([str(TRELLO_LAUNCHER), flag], timeout=45)
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        runtime = payload.get("launcher_runtime") or {}
        print("CodeX MCP Doctor")
        print("")
        print(f"Status: {'OK' if payload.get('ok') else 'NO'}")
        print(f"Credential source: {runtime.get('credential_source') or 'unknown'}")
        print(f"1Password: {(runtime.get('op_resolution') or {}).get('status') or 'unknown'}")
        rec = payload.get("recommendation")
        if rec:
            print(f"Recommendation: {rec}")
    return 0 if payload.get("ok") else 1


def reload_env(json_mode: bool) -> int:
    result = run([str(ENV_LOADER)], timeout=60)
    status = json_command([str(TRELLO_LAUNCHER), "--status"], timeout=20)
    payload = {
        "ok": result.returncode == 0 and bool(status.get("ok")),
        "env_loader_output": (result.stdout or result.stderr).strip(),
        "trello_status": status,
        "note": "Codex app may need a restart for MCP tool-list changes; API env is refreshed now.",
        "safety": {"secrets_returned": False},
    }
    if json_mode:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX MCP reload")
        print("")
        print(payload["env_loader_output"] or f"env loader exit {result.returncode}")
        print(f"Trello credential source: {status.get('credential_source') or 'unknown'}")
        print(payload["note"])
    return 0 if payload["ok"] else 1


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="CodeX MCP control panel")
    parser.add_argument("--json", action="store_true")
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("status")
    tools = sub.add_parser("tools")
    tools.add_argument("--include-writes", action="store_true")
    test = sub.add_parser("trello-test")
    test.add_argument("query", nargs="?", default="Byrd")
    doc = sub.add_parser("doctor")
    doc.add_argument("--live", action="store_true")
    sub.add_parser("reload")
    args = parser.parse_args(argv)

    if args.command == "status":
        return print_status(args.json)
    if args.command == "tools":
        return print_tools(args.json, args.include_writes)
    if args.command == "trello-test":
        return trello_test(args.query, args.json)
    if args.command == "doctor":
        return doctor(args.live, args.json)
    if args.command == "reload":
        return reload_env(args.json)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
