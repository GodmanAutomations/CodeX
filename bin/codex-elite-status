#!/usr/bin/env bash
set -euo pipefail

ROOT="${1:-/Users/stephengodman/CodeX}"
CODEX_BIN="${CODEX_BIN:-/Users/stephengodman/.local/bin/codex}"

section() {
  printf '\n## %s\n' "$1"
}

section "Codex"
if command -v "$CODEX_BIN" >/dev/null 2>&1; then
  "$CODEX_BIN" --version
else
  codex --version
fi

section "Git"
git -C "$ROOT" branch --show-current
git -C "$ROOT" status --short

section "Open PRs"
if command -v gh >/dev/null 2>&1; then
  gh pr list --repo GodmanAutomations/CodeX --state open --json number,title,headRefName,reviewDecision,statusCheckRollup,url
else
  echo "gh unavailable"
fi

section "Cloud Tasks"
if command -v "$CODEX_BIN" >/dev/null 2>&1; then
  "$CODEX_BIN" cloud list --json --limit 10
else
  codex cloud list --json --limit 10
fi

section "Plugins"
if command -v "$CODEX_BIN" >/dev/null 2>&1; then
  "$CODEX_BIN" plugin list | rg 'codex-security|record-and-replay|openai-developers|github@openai-curated|google-drive@openai-curated|cloudflare@openai-curated|vercel@openai-curated' || true
else
  codex plugin list | rg 'codex-security|record-and-replay|openai-developers|github@openai-curated|google-drive@openai-curated|cloudflare@openai-curated|vercel@openai-curated' || true
fi

section "App Server"
if command -v "$CODEX_BIN" >/dev/null 2>&1; then
  "$CODEX_BIN" app-server daemon version || true
else
  codex app-server daemon version || true
fi
