#!/usr/bin/env python3
"""Classify CodeX git-tree drift and write a cleanup receipt.

This is intentionally conservative. It inventories and classifies the worktree;
it does not revert, delete, stage, or commit anything.
"""
from __future__ import annotations

import argparse
import fnmatch
import json
import os
import re
import subprocess
import sys
from dataclasses import asdict, dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


ROOT = Path("/Users/stephengodman/CodeX")
RECEIPT_ROOT = ROOT / "receipts" / "tree-steward"
POLICY_PATH = ROOT / "config" / "tree-steward-policy.json"
RECEIPT_SCHEMA_PATH = ROOT / "config" / "tree-steward-receipt.schema.json"
DEFAULT_BLOCK_CATEGORIES = {
    "needs_human_review",
    "risky_or_revert_sensitive",
    "ignored_or_archive_candidate",
}
DEFAULT_CONTENT_SCAN_MAX_BYTES = 1_000_000


@dataclass
class Entry:
    status: str
    path: str
    category: str
    reason: str
    recommendation: str


@dataclass
class Finding:
    name: str
    path: str
    severity: str
    message: str
    line: int | None = None


@dataclass
class IgnoredAdvisory:
    status: str
    path: str
    category: str
    reason: str
    recommendation: str


def run_git(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(ROOT), *args],
        check=False,
        capture_output=True,
        text=True,
        timeout=20,
    )


def parse_status(include_ignored: bool = False) -> list[tuple[str, str]]:
    args = ["status", "--short", "--untracked-files=all"]
    if include_ignored:
        args.append("--ignored=matching")
    result = run_git(args)
    if result.returncode != 0:
        raise RuntimeError((result.stderr or result.stdout).strip())
    rows: list[tuple[str, str]] = []
    for line in result.stdout.splitlines():
        if not line:
            continue
        status = line[:2]
        path = line[3:] if len(line) > 3 else ""
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        rows.append((status, path))
    return rows


def load_policy() -> dict[str, object]:
    if not POLICY_PATH.exists():
        return {}
    return json.loads(POLICY_PATH.read_text(encoding="utf-8"))


def tracked_files() -> list[str]:
    result = run_git(["ls-files"])
    if result.returncode != 0:
        return []
    return [line for line in result.stdout.splitlines() if line]


def ignored_status_rows() -> list[tuple[str, str]]:
    return [(status, path) for status, path in parse_status(include_ignored=True) if status == "!!"]


def match_pattern(path: str, pattern: str) -> bool:
    if pattern.endswith("/**"):
        return path.startswith(pattern[:-3])
    return fnmatch.fnmatch(path, pattern)


def excluded(path: str, patterns: list[str]) -> bool:
    return any(match_pattern(path, pattern) for pattern in patterns)


def file_count(path: str) -> int | None:
    full = ROOT / path
    if not full.is_dir():
        return None
    count = 0
    for _, dirs, files in os.walk(full):
        dirs[:] = [d for d in dirs if d not in {".git", "__pycache__", ".venv", "node_modules"}]
        count += len(files)
        if count > 500:
            break
    return count


def policy_rule(policy: dict[str, object], path: str) -> dict[str, str] | None:
    for item in policy.get("path_rules", []):
        if not isinstance(item, dict):
            continue
        pattern = str(item.get("pattern") or "")
        if pattern and match_pattern(path, pattern):
            return {
                "category": str(item.get("category") or "needs_human_review"),
                "reason": str(item.get("reason") or "policy rule matched"),
                "recommendation": str(item.get("recommendation") or "review before staging"),
            }
    return None


def classify(status: str, path: str, policy: dict[str, object]) -> Entry:
    lowered = path.lower()
    is_delete = "D" in status
    is_untracked = status == "??"
    credential_tokens = [
        str(item).lower() for item in policy.get("credential_path_tokens", []) if str(item).strip()
    ] or [".env", "credential", "1password", "secret", "token"]

    if is_delete:
        return Entry(
            status=status,
            path=path,
            category="risky_or_revert_sensitive",
            reason="tracked deletion; could remove prior receipts or operating history",
            recommendation="review exact intent before restore, commit, or removal",
        )

    if any(part in lowered for part in credential_tokens):
        return Entry(
            status=status,
            path=path,
            category="risky_or_revert_sensitive",
            reason="credential or secret-adjacent surface",
            recommendation="review manually; do not print secrets or bulk-stage",
        )

    rule = policy_rule(policy, path)
    if rule:
        count = file_count(path)
        detail = f"; observed at least {count} files" if count and path.endswith("/") else ""
        return Entry(
            status=status,
            path=path,
            category=rule["category"],
            reason=rule["reason"] + detail,
            recommendation=rule["recommendation"],
        )

    return Entry(
        status=status,
        path=path,
        category="needs_human_review",
        reason="unclassified worktree change",
        recommendation="inspect before staging, deleting, or building on top of it",
    )


def classify_ignored(status: str, path: str, policy: dict[str, object]) -> IgnoredAdvisory:
    rule = policy_rule(policy, path)
    category = rule["category"] if rule else "ignored_or_archive_candidate"
    reason = rule["reason"] if rule else "ignored path visible to git status"
    recommendation = (
        rule["recommendation"]
        if rule
        else "keep ignored unless this path is intentionally adopted into the control repo"
    )
    return IgnoredAdvisory(
        status=status,
        path=path,
        category=category,
        reason=reason,
        recommendation=recommendation,
    )


def summarize(entries: list[Entry]) -> dict[str, int]:
    counts: dict[str, int] = {}
    for entry in entries:
        counts[entry.category] = counts.get(entry.category, 0) + 1
    return dict(sorted(counts.items()))


def content_scan_candidates(policy: dict[str, object], rows: list[tuple[str, str]]) -> list[str]:
    candidates = set(tracked_files())
    for _, relative in rows:
        if not relative or relative.endswith("/"):
            continue
        candidates.add(relative)
    excludes = [str(item) for item in policy.get("content_scan_excludes", [])]
    return sorted(relative for relative in candidates if not excluded(relative, excludes))


def read_text_for_scan(path: Path, max_bytes: int) -> str | None:
    try:
        if path.stat().st_size > max_bytes:
            return None
        raw = path.read_bytes()
    except OSError:
        return None
    if b"\0" in raw:
        return None
    try:
        return raw.decode("utf-8")
    except UnicodeDecodeError:
        return None


def scan_content(policy: dict[str, object], rows: list[tuple[str, str]]) -> list[Finding]:
    patterns = []
    for item in policy.get("content_checks", []):
        if not isinstance(item, dict):
            continue
        try:
            compiled = re.compile(str(item.get("pattern") or ""))
        except re.error:
            continue
        patterns.append((item, compiled))
    if not patterns:
        return []

    findings: list[Finding] = []
    max_bytes = int(policy.get("content_scan_max_bytes") or DEFAULT_CONTENT_SCAN_MAX_BYTES)
    allowed_secret_values = {
        str(item)
        for item in policy.get("raw_secret_assignment_allow_values", [])
        if str(item).strip()
    }
    for relative in content_scan_candidates(policy, rows):
        path = ROOT / relative
        if not path.is_file():
            continue
        text = read_text_for_scan(path, max_bytes)
        if text is None:
            continue
        for line_number, line in enumerate(text.splitlines(), start=1):
            for item, compiled in patterns:
                if compiled.search(line):
                    name = str(item.get("name") or "content_check")
                    if name == "raw_secret_assignment" and any(value in line for value in allowed_secret_values):
                        continue
                    findings.append(
                        Finding(
                            name=name,
                            path=relative,
                            severity=str(item.get("severity") or "warn"),
                            message=str(item.get("message") or "policy content check matched"),
                            line=line_number,
                        )
                    )
    return findings


def strict_pass(
    entries: list[Entry],
    findings: list[Finding],
    policy: dict[str, object],
    preflight: str | None = None,
) -> tuple[bool, int]:
    block_categories = set(
        str(item)
        for item in policy.get("strict_block_categories", [])
        if str(item).strip()
    ) or DEFAULT_BLOCK_CATEGORIES
    block_severities = {"block"}
    if preflight == "trello-mcp":
        preflight_policy = policy.get("trello_mcp_preflight", {})
        if isinstance(preflight_policy, dict):
            block_categories = set(
                str(item)
                for item in preflight_policy.get("blocked_categories", [])
                if str(item).strip()
            ) or block_categories
            block_severities = set(
                str(item)
                for item in preflight_policy.get("blocked_content_severities", [])
                if str(item).strip()
            ) or block_severities
    blockers = sum(1 for entry in entries if entry.category in block_categories)
    blockers += sum(1 for finding in findings if finding.severity in block_severities)
    return blockers == 0, blockers


def validate_receipt_payload(payload: dict[str, Any]) -> list[str]:
    required = {
        "ok": bool,
        "root": str,
        "generated_at": str,
        "dirty_count": int,
        "strict_pass": bool,
        "strict_blockers": int,
        "summary": dict,
        "entries": list,
        "findings": list,
        "ignored_advisories": list,
        "safety": dict,
    }
    errors = []
    for key, expected_type in required.items():
        if key not in payload:
            errors.append(f"missing {key}")
        elif not isinstance(payload[key], expected_type):
            errors.append(f"{key} should be {expected_type.__name__}")
    safety = payload.get("safety") if isinstance(payload.get("safety"), dict) else {}
    for key in ["git_writes", "file_deletes", "secrets_printed", "trello_writes"]:
        if not isinstance(safety.get(key), bool):
            errors.append(f"safety.{key} should be bool")
    return errors


def build_payload(policy: dict[str, object], preflight: str | None) -> dict[str, Any]:
    rows = parse_status()
    entries = [classify(status, path, policy) for status, path in rows]
    ignored_advisories = [
        classify_ignored(status, path, policy) for status, path in ignored_status_rows()
    ]
    findings = scan_content(policy, rows)
    summary = summarize(entries)
    strict_ok, strict_blockers = strict_pass(entries, findings, policy, preflight)
    payload: dict[str, Any] = {
        "ok": True,
        "root": str(ROOT),
        "policy_path": str(POLICY_PATH) if POLICY_PATH.exists() else None,
        "policy_version": policy.get("version"),
        "receipt_schema_path": str(RECEIPT_SCHEMA_PATH) if RECEIPT_SCHEMA_PATH.exists() else None,
        "preflight": preflight,
        "generated_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "dirty_count": len(entries),
        "strict_pass": strict_ok,
        "strict_blockers": strict_blockers,
        "summary": summary,
        "entries": [asdict(entry) for entry in entries],
        "findings": [asdict(finding) for finding in findings],
        "ignored_advisories": [asdict(advisory) for advisory in ignored_advisories],
        "safety": {
            "git_writes": False,
            "file_deletes": False,
            "secrets_printed": False,
            "trello_writes": False,
        },
    }
    schema_errors = validate_receipt_payload(payload)
    payload["schema_valid"] = not schema_errors
    payload["schema_errors"] = schema_errors
    return payload


def markdown(payload: dict[str, object]) -> str:
    entries = [Entry(**item) for item in payload["entries"]]  # type: ignore[arg-type]
    lines = [
        "# CodeX Tree Steward Receipt",
        "",
        f"- Generated: `{payload['generated_at']}`",
        f"- Root: `{payload['root']}`",
        f"- Dirty entries: `{payload['dirty_count']}`",
        f"- Strict pass: `{payload['strict_pass']}`",
        "",
        "## Summary",
        "",
    ]
    for category, count in payload["summary"].items():  # type: ignore[union-attr]
        lines.append(f"- `{category}`: {count}")
    lines.extend(["", "## Entries", ""])
    for entry in entries:
        lines.extend(
            [
                f"### `{entry.path}`",
                "",
                f"- Status: `{entry.status.strip() or entry.status}`",
                f"- Category: `{entry.category}`",
                f"- Reason: {entry.reason}",
                f"- Recommendation: {entry.recommendation}",
                "",
            ]
        )
    if not entries:
        lines.append("Tree is clean.")
    advisories = [
        IgnoredAdvisory(**item) for item in payload.get("ignored_advisories", [])  # type: ignore[arg-type]
    ]
    lines.extend(["", "## Ignored Advisories", ""])
    if advisories:
        for advisory in advisories[:25]:
            lines.extend(
                [
                    f"### `{advisory.path}`",
                    "",
                    f"- Status: `{advisory.status.strip() or advisory.status}`",
                    f"- Category: `{advisory.category}`",
                    f"- Reason: {advisory.reason}",
                    f"- Recommendation: {advisory.recommendation}",
                    "",
                ]
            )
    else:
        lines.append("No ignored advisory paths visible.")
    findings = [Finding(**item) for item in payload.get("findings", [])]  # type: ignore[arg-type]
    lines.extend(["", "## Policy Findings", ""])
    if findings:
        for finding in findings:
            location = finding.path if finding.line is None else f"{finding.path}:{finding.line}"
            lines.extend(
                [
                    f"### `{finding.name}`",
                    "",
                    f"- Location: `{location}`",
                    f"- Severity: `{finding.severity}`",
                    f"- Message: {finding.message}",
                    "",
                ]
            )
    else:
        lines.append("No policy content findings.")
    lines.extend(
        [
            "## Safety",
            "",
            "- Git writes: `false`",
            "- File deletes: `false`",
            "- Secrets printed: `false`",
            "- Trello writes: `false`",
            "",
        ]
    )
    return "\n".join(lines)


def write_receipts(payload: dict[str, Any]) -> None:
    RECEIPT_ROOT.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    json_path = RECEIPT_ROOT / f"{stamp}-tree-steward.json"
    md_path = RECEIPT_ROOT / f"{stamp}-tree-steward.md"
    payload["receipt_json"] = str(json_path)
    payload["receipt_markdown"] = str(md_path)
    json_path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    md_path.write_text(markdown(payload), encoding="utf-8")


def run_doctor(json_mode: bool) -> int:
    policy = load_policy()
    doctor_id = f"{os.getpid()}-{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}"
    secret_probe_name = f"TREE_STEWARD_DOCTOR_SECRET_{doctor_id}.md"
    mcp_probe_name = f"tree_steward_doctor_probe_{doctor_id}.py"
    probes = [
        ROOT / secret_probe_name,
        ROOT / "mcp_servers" / mcp_probe_name,
    ]
    checks: list[dict[str, Any]] = []
    try:
        stale_path_probe = "REDACTED" + "-Code"
        label_only_probe = "api" + "_key label only; Authorization: Bearer <redacted>"
        secret_assignment_probe = (
            "api" + "_key = 'notarealsecretvalueusedforpolicydoctor000000'"
        )
        probes[0].write_text(
            "doctor probe\n"
            f"{label_only_probe}\n"
            f"legacy_path = '{stale_path_probe}'\n"
            f"{secret_assignment_probe}\n",
            encoding="utf-8",
        )
        probes[1].write_text("# doctor probe\nprint('tree steward doctor')\n", encoding="utf-8")
        payload = build_payload(policy, "trello-mcp")
        checks.append(
            {
                "name": "receipt_payload_schema",
                "ok": bool(payload.get("schema_valid")),
                "detail": payload.get("schema_errors") or [],
            }
        )
        secret_findings = [
            item for item in payload["findings"] if Path(item["path"]).name == secret_probe_name
        ]
        label_findings = [
            item for item in secret_findings if item["name"] == "sensitive_label_only"
        ]
        blocking_findings = [
            item for item in secret_findings if item["severity"] == "block"
        ]
        checks.append(
            {
                "name": "untracked_content_scan",
                "ok": len(secret_findings) >= 2,
                "detail": [item["name"] for item in secret_findings],
            }
        )
        checks.append(
            {
                "name": "label_findings_do_not_block",
                "ok": bool(label_findings) and all(item["severity"] == "warn" for item in label_findings),
                "detail": [item["severity"] for item in label_findings],
            }
        )
        mcp_entries = [
            item
            for item in payload["entries"]
            if item["path"] == f"mcp_servers/{mcp_probe_name}"
        ]
        checks.append(
            {
                "name": "untracked_mcp_classification",
                "ok": bool(mcp_entries)
                and mcp_entries[0]["category"] in {"needs_human_review", "risky_or_revert_sensitive"},
                "detail": mcp_entries[0]["category"] if mcp_entries else "missing",
            }
        )
        checks.append(
            {
                "name": "trello_preflight_blocks_values_not_labels",
                "ok": not payload["strict_pass"]
                and payload["strict_blockers"] >= len(blocking_findings)
                and bool(label_findings)
                and all(item["severity"] == "warn" for item in label_findings),
                "detail": {
                    "strict_blockers": payload["strict_blockers"],
                    "secret_findings": len(secret_findings),
                    "blocking_findings": len(blocking_findings),
                    "label_findings": len(label_findings),
                },
            }
        )
        output = {
            "ok": all(item["ok"] for item in checks),
            "checks": checks,
            "safety": {
                "git_writes": False,
                "file_deletes": False,
                "secrets_printed": False,
                "trello_writes": False,
            },
        }
    finally:
        for probe in probes:
            try:
                probe.unlink()
            except OSError:
                pass
    if json_mode:
        print(json.dumps(output, indent=2, sort_keys=True))
    else:
        print("CodeX Tree Steward Doctor")
        for check in output["checks"]:
            print(f"- {check['name']}: {'OK' if check['ok'] else 'NO'}")
    return 0 if output["ok"] else 1


def main() -> int:
    parser = argparse.ArgumentParser(description="Classify dirty CodeX tree state")
    parser.add_argument("--json", action="store_true", help="Print JSON instead of a plain summary.")
    parser.add_argument("--no-receipt", action="store_true", help="Do not write receipt files.")
    parser.add_argument("--strict", action="store_true", help="Exit non-zero when risky or review-needed items exist.")
    parser.add_argument(
        "--preflight",
        choices=["trello-mcp"],
        help="Apply a named preflight policy while classifying the tree.",
    )
    parser.add_argument("--doctor", action="store_true", help="Run behavioral self-checks.")
    args = parser.parse_args()

    if args.doctor:
        return run_doctor(args.json)

    policy = load_policy()
    payload = build_payload(policy, args.preflight)

    if not args.no_receipt:
        write_receipts(payload)

    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print("CodeX Tree Steward")
        print(f"root={payload['root']}")
        print(f"dirty_count={payload['dirty_count']}")
        print(f"strict_pass={payload['strict_pass']}")
        print(f"strict_blockers={payload['strict_blockers']}")
        if args.preflight:
            print(f"preflight={args.preflight}")
        for category, count in payload["summary"].items():
            print(f"{category}={count}")
        ignored_count = len(payload.get("ignored_advisories", []))
        if ignored_count:
            print(f"ignored_advisories={ignored_count}")
            for advisory in payload["ignored_advisories"][:8]:
                print(f"- ignored: {advisory['path']} ({advisory['category']})")
        findings = [Finding(**item) for item in payload.get("findings", [])]
        if findings:
            print(f"policy_findings={len(findings)}")
            for finding in findings[:8]:
                location = finding.path if finding.line is None else f"{finding.path}:{finding.line}"
                print(f"- {finding.severity}: {finding.name} at {location}")
        if not args.no_receipt:
            print(f"receipt={payload['receipt_markdown']}")

    if "strict_blockers" not in payload:
        raise RuntimeError("tree steward payload missing strict_blockers")
    return 1 if args.strict and payload["strict_blockers"] else 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"codex-tree-steward: {exc}", file=sys.stderr)
        raise SystemExit(2)
