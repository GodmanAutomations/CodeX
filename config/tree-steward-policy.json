{
  "version": 1,
  "description": "CodeX worktree hygiene policy for autonomous Trello MCP and room-control work.",
  "strict_block_categories": [
    "needs_human_review",
    "risky_or_revert_sensitive",
    "ignored_or_archive_candidate"
  ],
  "path_rules": [
    {
      "pattern": ".gitignore",
      "category": "safe_to_review",
      "reason": "repo hygiene policy",
      "recommendation": "review for broad ignore rules before commit"
    },
    {
      "pattern": "agents/codex-tree-steward/**",
      "category": "safe_to_review",
      "reason": "tree steward agent instructions",
      "recommendation": "verify the agent card is scoped and non-destructive"
    },
    {
      "pattern": "attachment-vault/**",
      "category": "ignored_or_archive_candidate",
      "reason": "large/local private-mail-adjacent project outside Trello MCP work",
      "recommendation": "keep ignored or adopt as a separate project; do not mix into Trello MCP commits"
    },
    {
      "pattern": "bin/**",
      "category": "needs_human_review",
      "reason": "executable surface",
      "recommendation": "run a focused syntax or smoke test before commit"
    },
    {
      "pattern": "mcp_servers/**",
      "category": "needs_human_review",
      "reason": "MCP server surface",
      "recommendation": "run MCP status and focused smoke tests before commit"
    },
    {
      "pattern": "launchd/**",
      "category": "needs_human_review",
      "reason": "service-control surface",
      "recommendation": "verify launch behavior before commit"
    },
    {
      "pattern": "work-notes/candice*",
      "category": "risky_or_revert_sensitive",
      "reason": "Candice/Kandice wiring is intentionally paused",
      "recommendation": "do not rewire Candice/Kandice unless Stephen explicitly asks"
    },
    {
      "pattern": "work-notes/trello*",
      "category": "safe_to_review",
      "reason": "Trello MCP note",
      "recommendation": "stage only if it matches the active Trello MCP slice"
    },
    {
      "pattern": "work-notes/INDEX.md",
      "category": "safe_to_review",
      "reason": "work-note index",
      "recommendation": "review generated index churn before commit"
    },
    {
      "pattern": "*.md",
      "category": "safe_to_review",
      "reason": "documentation or note file",
      "recommendation": "review content before deciding whether it belongs in the repo"
    }
  ],
  "credential_path_tokens": [
    ".env",
    "credential",
    "1password",
    "secret",
    "token"
  ],
  "content_checks": [
    {
      "name": "stale_redacted_code_path",
      "pattern": "REDACTED-Code",
      "severity": "block",
      "message": "Stale redacted CodeX path in a live repo file"
    },
    {
      "name": "stale_redacted_pi_path",
      "pattern": "redacted_(home|v2)",
      "severity": "block",
      "message": "Stale redacted Pi/Candice path in a live repo file"
    },
    {
      "name": "stale_profile_typo",
      "pattern": "0stephen-profile",
      "severity": "block",
      "message": "Stale credential profile typo; use .claude/stephen-profile"
    },
    {
      "name": "private_key_material",
      "pattern": "-----BEGIN (RSA |OPENSSH |EC |DSA |PRIVATE )?PRIVATE KEY-----",
      "severity": "block",
      "message": "Private key material appears in a tracked text file"
    },
    {
      "name": "raw_secret_assignment",
      "pattern": "(?i)(api[_-]?key|token|secret|password)\\s*=\\s*['\\\"]?[A-Za-z0-9_./+=-]{24,}",
      "severity": "warn",
      "message": "Possible raw secret assignment; inspect without printing values"
    }
  ],
  "content_scan_excludes": [
    "config/tree-steward-policy.json",
    ".git/**",
    "private/**",
    "receipts/**",
    "work-artifacts/**",
    "attachment-vault/**",
    "Coding Anchor Files/**",
    "Codex's Secret Sauce/**",
    "measurement-pipeline-v2/**",
    "__pycache__/**"
  ],
  "trello_mcp_preflight": {
    "description": "Required before Trello MCP build or apply-like slices.",
    "commands": [
      "/Users/stephengodman/CodeX/bin/codex-tree-steward --strict",
      "/Users/stephengodman/CodeX/bin/codex-mcp status"
    ],
    "blocked_categories": [
      "needs_human_review",
      "risky_or_revert_sensitive",
      "ignored_or_archive_candidate"
    ],
    "blocked_content_severities": [
      "block"
    ],
    "candice_rewire_requires_explicit_instruction": true
  }
}
