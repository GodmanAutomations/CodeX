# CodeX local control repo ignore policy
#
# Track durable room instructions, scripts, MCP servers, and concise receipts.
# Do not track private journals, secret files, generated artifacts, caches,
# logs, local databases, screenshots, bulky reference archives, or nested repos.

.DS_Store
**/.DS_Store

# Local app/agent state
.claude/
.codex/
.mcp.json
.playwright-mcp/
.pytest_cache/
.remember/
.tmp/
tmp/
output/
pulled/
logs/
receipts/
private/
HEARTBEAT.json
continuity/one-true-sentence.*
codex_continuity/tomorrow/
browser/artifacts/
evals/results/
notebooklm-packets/

# Databases, caches, generated Python state
__pycache__/
*.py[cod]
*.sqlite
*.sqlite3
*.db
*.db-*
*.log

# Secrets and local env
.env
.env.*
*.pem
*.key
*.token
*.secret

# Generated or bulky artifacts
backups/
work-artifacts/
dashboard/index.html
mcp_servers/*.before-*
research/
play/
venice/results/
venice/characters/
list_of_superskills.py
